---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Wordmark from '../components/Wordmark.astro';
---

<Base title="Sign in">
  <div class="auth-shell">
    <div class="auth-card">
      <a href="/" aria-label="pacelore home">
        <Wordmark height={28} />
      </a>
      <div>
        <h2 class="h2" style="font-size: 22px;">Sign in</h2>
        <p class="muted body-sm" style="margin-top: 6px;">
          Your data, your archive. Free for athletes.
        </p>
      </div>

      <form id="login-form" class="stack" style="gap: 14px;">
        <div class="field">
          <label class="field-label" for="login-email">Email</label>
          <input
            id="login-email"
            class="input"
            required
            name="email"
            type="email"
            autocomplete="email"
          />
        </div>
        <button type="submit" class="btn btn-primary btn-lg">
          <Icon name="key" size={14} /> Continue with passkey
        </button>
        <p id="login-status" class="caption" aria-live="polite"></p>
      </form>

      <p class="caption" style="text-align: center;">
        New here? <a href="/register" style="color: var(--fg); text-decoration: underline;">Create an account</a>
      </p>
    </div>
  </div>
</Base>

<script>
  import { startAuthentication } from '@simplewebauthn/browser';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const status = document.getElementById('login-status')!;
  const submit = form.querySelector('button[type=submit]') as HTMLButtonElement;

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    status.textContent = '';
    submit.disabled = true;
    try {
      const email = String(new FormData(form).get('email') ?? '').trim();
      const optionsRes = await fetch('/api/v1/auth/login/options', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (!optionsRes.ok)
        throw new Error(
          (await optionsRes.json().catch(() => ({ error: optionsRes.statusText }))).error,
        );
      const optionsBody = (await optionsRes.json()) as {
        challengeId: string;
        options: { challenge: string };
        rpMismatch?: { storedRpId: string; currentRpId: string };
      };
      if (optionsBody.rpMismatch) {
        throw new Error(
          `Your passkey was registered under "${optionsBody.rpMismatch.storedRpId}" — this site is now "${optionsBody.rpMismatch.currentRpId}". Register a new passkey for this domain (Settings → security) or contact support to migrate.`,
        );
      }
      const { challengeId, options } = optionsBody;

      const assertion = await startAuthentication({ optionsJSON: options });

      const verifyRes = await fetch('/api/v1/auth/login/verify', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ challengeId, response: assertion }),
      });
      if (!verifyRes.ok)
        throw new Error(
          (await verifyRes.json().catch(() => ({ error: verifyRes.statusText }))).error,
        );

      status.textContent = 'Signed in — redirecting…';
      const next = new URL(window.location.href).searchParams.get('next');
      window.location.href = next && next.startsWith('/') ? next : '/dashboard';
    } catch (err) {
      status.textContent = `Couldn't sign in: ${(err as Error).message}`;
      submit.disabled = false;
    }
  });
</script>
