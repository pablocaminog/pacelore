---
import Shell from '../layouts/Shell.astro';
import Icon from '../components/Icon.astro';
---

<Shell title="Calendar" active="calendar">
  <div class="stack" style="gap: 16px;">
    <header style="display: flex; align-items: center; gap: 12px;">
      <div style="flex: 1;">
        <h1 class="h1" style="font-size: 28px;">Calendar</h1>
        <p id="cal-subtitle" class="muted body-sm" style="margin-top: 4px;">Loading…</p>
      </div>
      <div class="segmented" id="cal-range">
        <button type="button" data-w="6" class="">6 wk</button>
        <button type="button" data-w="12" class="on">12 wk</button>
        <button type="button" data-w="24">24 wk</button>
        <button type="button" data-w="52">52 wk</button>
      </div>
    </header>

    <div class="cal-wrap" id="cal-wrap">
      <div class="cal-loading caption">Loading calendar…</div>
    </div>
  </div>
</Shell>

<style is:global>
  .cal-wrap {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    overflow-x: auto;
  }
  .cal-grid {
    display: grid;
    grid-template-columns: 220px repeat(7, minmax(140px, 1fr));
    min-width: 1180px;
  }
  .cal-head {
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    text-align: center;
  }
  .cal-head.left {
    text-align: left;
  }
  .cal-week {
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 12px 14px;
    background: var(--surface-2);
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
  }
  .cal-week-label {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .cal-week-label strong {
    font-size: 14px;
  }
  .cal-week-totals {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 12px;
    row-gap: 4px;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 12px;
  }
  .cal-week-totals .k {
    color: var(--fg-muted);
  }
  .cal-week-pmc {
    border-top: 1px solid var(--border);
    padding-top: 6px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
  }
  .cal-week-pmc .v {
    font-size: 13px;
  }
  .cal-day {
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 96px;
  }
  .cal-day:last-child {
    border-right: none;
  }
  .cal-day.today {
    background: var(--accent-soft);
  }
  .cal-day-head {
    display: flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
  }
  .cal-day-head .future {
    opacity: 0.5;
  }
  .cal-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    transition: border-color 120ms var(--ease-out);
  }
  .cal-card:hover {
    border-color: var(--border-strong);
  }
  .cal-card-top {
    background: var(--ink-50);
    padding: 4px 8px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 12px;
  }
  .cal-card-top .sport {
    width: 14px;
    height: 14px;
    color: var(--fg);
    flex-shrink: 0;
  }
  .cal-card-top .duration {
    font-weight: 600;
    color: var(--fg);
  }
  .cal-card-top .distance {
    margin-left: auto;
    color: var(--fg-muted);
  }
  .cal-card.sport-cycling .cal-card-top {
    background: oklch(0.92 0.02 240);
    border-bottom-color: oklch(0.85 0.02 240);
  }
  .cal-card.sport-running .cal-card-top {
    background: oklch(0.94 0.04 35);
    border-bottom-color: oklch(0.86 0.06 35);
  }
  .cal-card.sport-swimming .cal-card-top {
    background: oklch(0.94 0.04 200);
    border-bottom-color: oklch(0.86 0.05 200);
  }
  .cal-card.sport-other .cal-card-top {
    background: var(--ink-100);
    border-bottom-color: var(--ink-200);
  }
  :root[data-theme='dark'] .cal-card.sport-cycling .cal-card-top,
  :root.dark .cal-card.sport-cycling .cal-card-top {
    background: oklch(0.28 0.05 240);
  }
  :root[data-theme='dark'] .cal-card.sport-running .cal-card-top,
  :root.dark .cal-card.sport-running .cal-card-top {
    background: oklch(0.30 0.08 35);
  }
  :root[data-theme='dark'] .cal-card.sport-swimming .cal-card-top,
  :root.dark .cal-card.sport-swimming .cal-card-top {
    background: oklch(0.30 0.06 200);
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .cal-card.sport-cycling .cal-card-top {
      background: oklch(0.28 0.05 240);
    }
    :root:not([data-theme='light']) .cal-card.sport-running .cal-card-top {
      background: oklch(0.30 0.08 35);
    }
    :root:not([data-theme='light']) .cal-card.sport-swimming .cal-card-top {
      background: oklch(0.30 0.06 200);
    }
  }
  .cal-card-body {
    padding: 6px 8px;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 11px;
    color: var(--fg);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cal-card-body .row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    align-items: baseline;
  }
  .cal-card-body .row .k {
    color: var(--fg-muted);
  }
  .cal-card-name {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.25;
    border-top: 1px solid var(--border);
    padding-top: 4px;
    margin-top: 2px;
  }
  .cal-card-source {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-subtle);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .cal-loading {
    padding: 32px;
    text-align: center;
  }
</style>

<script>
  type Activity = {
    id: string;
    sport: string;
    name: string | null;
    startedAt: number;
    totalSeconds: number;
    distanceM: number | null;
    ascentM: number | null;
    hrAvg: number | null;
    hrMax: number | null;
    powerAvg: number | null;
    powerMax: number | null;
    np: number | null;
    tss: number | null;
    kj: number | null;
    speedAvgMs: number | null;
    source: string;
    externalSource: string | null;
    externalId: string | null;
  };
  type PmcDay = { date: string; ctl: number; atl: number; tsb: number; tss: number };
  type WellnessDay = {
    date: string;
    source: string;
    sleepSeconds: number | null;
    sleepScore: number | null;
    rhr: number | null;
    hrv: number | null;
    steps: number | null;
    weightKg: number | null;
    bodyBattery: number | null;
    stressAvg: number | null;
  };

  const subtitle = document.getElementById('cal-subtitle')!;
  const wrap = document.getElementById('cal-wrap')!;
  const rangeTabs = document.getElementById('cal-range')!;
  let weeks = 12;
  let user: { id: string; handle: string } | null = null;

  rangeTabs.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement;
    const w = t.dataset.w;
    if (!w) return;
    rangeTabs.querySelectorAll('button').forEach((b) => b.classList.toggle('on', b === t));
    weeks = Number(w);
    void render();
  });

  init().catch((err) => (subtitle.textContent = `Couldn't load: ${(err as Error).message}`));

  async function init() {
    const me = await fetch('/api/v1/auth/me', { credentials: 'include' });
    if (!me.ok) {
      subtitle.innerHTML =
        'Sign in to see your calendar — <a href="/login" style="color: var(--fg); text-decoration: underline;">go to sign in</a>.';
      wrap.innerHTML = '';
      return;
    }
    user = ((await me.json()) as { user: { id: string; handle: string } }).user;
    await render();
  }

  async function render() {
    if (!user) return;
    const { weeksBack, monday, sunday } = computeRange(weeks);
    const fromIso = isoDate(monday);
    const toIso = isoDate(sunday);
    wrap.innerHTML = '<div class="cal-loading caption">Loading…</div>';

    const [actsRes, pmcRes, wellRes] = await Promise.all([
      fetch(`/api/v1/me/calendar/activities?from=${fromIso}&to=${toIso}`, {
        credentials: 'include',
      }),
      fetch(`/api/v1/athletes/${user.id}/pmc?from=${fromIso}&to=${toIso}`, {
        credentials: 'include',
      }),
      fetch(`/api/v1/me/wellness?from=${fromIso}&to=${toIso}`, {
        credentials: 'include',
      }),
    ]);
    if (!actsRes.ok) {
      wrap.innerHTML = `<div class="cal-loading caption" style="color: var(--danger);">Couldn't load activities · HTTP ${actsRes.status}</div>`;
      return;
    }
    const acts = ((await actsRes.json()) as { items: Activity[] }).items;
    const pmc = pmcRes.ok ? ((await pmcRes.json()) as { days: PmcDay[] }).days : [];
    const pmcByDate = new Map(pmc.map((d) => [d.date, d]));
    const wellness = wellRes.ok
      ? ((await wellRes.json()) as { items: WellnessDay[] }).items
      : [];
    const wellByDate = new Map(wellness.map((w) => [w.date, w]));

    // Bucket activities by ISO date string (athlete-local — UTC for now).
    const byDay = new Map<string, Activity[]>();
    for (const a of acts) {
      const key = isoDate(new Date(a.startedAt * 1000));
      const list = byDay.get(key) ?? [];
      list.push(a);
      byDay.set(key, list);
    }

    const today = isoDate(new Date());
    const grid: string[] = [];
    grid.push(buildHeader());

    for (let i = 0; i < weeksBack; i++) {
      const weekMonday = new Date(monday);
      weekMonday.setUTCDate(monday.getUTCDate() + i * 7);
      const weekSunday = new Date(weekMonday);
      weekSunday.setUTCDate(weekMonday.getUTCDate() + 6);
      grid.push(buildWeek(weekMonday, weekSunday, byDay, pmcByDate, wellByDate, today));
    }

    wrap.innerHTML = `<div class="cal-grid">${grid.join('')}</div>`;
    subtitle.textContent = `${user.handle} · ${weeksBack} weeks · ${acts.length} activities`;
  }

  function buildHeader(): string {
    const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    return `
      <div class="cal-head left">Week</div>
      ${days.map((d) => `<div class="cal-head">${d}</div>`).join('')}
    `;
  }

  function buildWeek(
    monday: Date,
    sunday: Date,
    byDay: Map<string, Activity[]>,
    pmcByDate: Map<string, PmcDay>,
    wellByDate: Map<string, WellnessDay>,
    today: string,
  ): string {
    let totalSec = 0;
    let totalDist = 0;
    let totalKj = 0;
    let totalLoad = 0;
    const sportTimes = new Map<string, number>();
    const sportDists = new Map<string, number>();
    const dayCells: string[] = [];

    for (let d = 0; d < 7; d++) {
      const day = new Date(monday);
      day.setUTCDate(monday.getUTCDate() + d);
      const key = isoDate(day);
      const acts = byDay.get(key) ?? [];
      for (const a of acts) {
        totalSec += a.totalSeconds;
        if (a.distanceM) totalDist += a.distanceM;
        if (a.kj) totalKj += a.kj;
        if (a.tss) totalLoad += a.tss;
        sportTimes.set(a.sport, (sportTimes.get(a.sport) ?? 0) + a.totalSeconds);
        if (a.distanceM)
          sportDists.set(a.sport, (sportDists.get(a.sport) ?? 0) + a.distanceM);
      }
      dayCells.push(buildDay(day, key, acts, wellByDate.get(key) ?? null, today));
    }

    const sundayKey = isoDate(sunday);
    const pmc = pmcByDate.get(sundayKey);
    const isoWeek = isoWeekNumber(sunday);

    return `
      <div class="cal-week">
        <div class="cal-week-label">
          <span class="metric-label" style="color: var(--fg-muted);">Week</span>
          <strong>${isoWeek}</strong>
        </div>
        <div class="cal-week-totals">
          <span class="k">Time</span>
          <span>${formatHm(totalSec) || '—'}</span>
          <span class="k">Dist</span>
          <span>${totalDist > 0 ? `${(totalDist / 1000).toFixed(1)} km` : '—'}</span>
          <span class="k">Load</span>
          <span>${totalLoad > 0 ? totalLoad.toFixed(0) : '—'}</span>
          <span class="k">kJ</span>
          <span>${totalKj > 0 ? totalKj.toFixed(0) : '—'}</span>
        </div>
        ${
          sportTimes.size > 0
            ? `<div style="display: grid; grid-template-columns: 16px 1fr 1fr; gap: 4px 10px; font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-size: 11px;">
              ${[...sportTimes.entries()]
                .map(
                  ([sport, sec]) => `
                <span>${sportGlyph(sport)}</span>
                <span>${formatHm(sec)}</span>
                <span style="color: var(--fg-muted);">${
                  sportDists.has(sport)
                    ? `${(sportDists.get(sport)! / 1000).toFixed(1)} km`
                    : '—'
                }</span>
              `,
                )
                .join('')}
            </div>`
            : ''
        }
        ${
          pmc
            ? `<div class="cal-week-pmc">
              <div><span class="k metric-label" style="color: var(--fg-muted);">CTL</span><div class="v">${pmc.ctl.toFixed(0)}</div></div>
              <div><span class="k metric-label" style="color: var(--fg-muted);">ATL</span><div class="v">${pmc.atl.toFixed(0)}</div></div>
              <div><span class="k metric-label" style="color: var(--fg-muted);">TSB</span><div class="v">${pmc.tsb.toFixed(0)}</div></div>
            </div>`
            : ''
        }
      </div>
      ${dayCells.join('')}
    `;
  }

  function buildDay(
    date: Date,
    key: string,
    acts: Activity[],
    well: WellnessDay | null,
    today: string,
  ): string {
    const isToday = key === today;
    const isFuture = key > today;
    const cards = acts.map(buildCard).join('');
    const monthShort = date.toLocaleDateString(undefined, {
      month: 'short',
      timeZone: 'UTC',
    });
    const wellRow = well ? buildWellnessRow(well) : '';
    return `
      <div class="cal-day${isToday ? ' today' : ''}">
        <div class="cal-day-head ${isFuture ? 'future' : ''}">
          <span>${monthShort} ${date.getUTCDate()}</span>
          ${wellRow}
        </div>
        ${cards}
      </div>
    `;
  }

  function buildWellnessRow(w: WellnessDay): string {
    const parts: string[] = [];
    if (w.sleepSeconds != null) {
      const h = Math.floor(w.sleepSeconds / 3600);
      const m = Math.floor((w.sleepSeconds % 3600) / 60);
      parts.push(
        `<span title="Sleep">🌙 ${h}h${String(m).padStart(2, '0')}${
          w.sleepScore != null ? ` · ${w.sleepScore}` : ''
        }</span>`,
      );
    }
    if (w.rhr != null) parts.push(`<span title="Resting HR">♥ ${w.rhr}</span>`);
    if (w.hrv != null) parts.push(`<span title="HRV (ms)">HRV ${Math.round(w.hrv)}</span>`);
    if (w.steps != null && w.steps > 0)
      parts.push(`<span title="Steps">${(w.steps / 1000).toFixed(1)}k</span>`);
    if (w.weightKg != null) parts.push(`<span title="Weight">${w.weightKg.toFixed(1)}kg</span>`);
    if (parts.length === 0) return '';
    return `<span class="cal-wellness" style="margin-left: auto; display: flex; gap: 6px; font-size: 10px; color: var(--fg-subtle);">${parts.join(' ')}</span>`;
  }

  function buildCard(a: Activity): string {
    const sport = (a.sport ?? 'other').toLowerCase();
    const sportClass = ['cycling', 'running', 'swimming'].includes(sport)
      ? `sport-${sport}`
      : 'sport-other';
    const dist = a.distanceM != null ? `${(a.distanceM / 1000).toFixed(1)} km` : '';
    const dur = formatHm(a.totalSeconds) || '0m';
    const stats: string[] = [];
    if (a.hrAvg != null) stats.push(`<span><span class="k">HR</span> ${Math.round(a.hrAvg)}</span>`);
    if (a.powerAvg != null)
      stats.push(`<span><span class="k">P</span> ${Math.round(a.powerAvg)}w</span>`);
    if (a.np != null) stats.push(`<span><span class="k">NP</span> ${Math.round(a.np)}w</span>`);
    if (a.tss != null) stats.push(`<span><span class="k">TSS</span> ${a.tss.toFixed(0)}</span>`);
    if (a.ascentM != null && a.ascentM > 0)
      stats.push(`<span><span class="k">↑</span> ${Math.round(a.ascentM)}m</span>`);

    const name = a.name ?? sentenceCase(sport);
    const source = sourceLabel(a);

    return `
      <a class="cal-card ${sportClass}" href="/activity/${escape(a.id)}">
        <div class="cal-card-top">
          <span class="sport">${sportGlyph(sport)}</span>
          <span class="duration">${escape(dur)}</span>
          ${dist ? `<span class="distance">${escape(dist)}</span>` : ''}
        </div>
        <div class="cal-card-body">
          ${stats.length ? `<div class="row">${stats.join('')}</div>` : ''}
          <div class="cal-card-name">${escape(name)}</div>
          <div class="cal-card-source">${escape(source)}</div>
        </div>
      </a>
    `;
  }

  // ---------------- helpers ----------------

  function computeRange(n: number): { weeksBack: number; monday: Date; sunday: Date } {
    // Anchor "now" to UTC midnight, then walk back to the Monday of the
    // week n-1 weeks before this one. Returns inclusive range.
    const now = new Date();
    const todayUtc = new Date(
      Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()),
    );
    const dow = (todayUtc.getUTCDay() + 6) % 7; // Mon=0..Sun=6
    const thisMonday = new Date(todayUtc);
    thisMonday.setUTCDate(todayUtc.getUTCDate() - dow);
    const monday = new Date(thisMonday);
    monday.setUTCDate(thisMonday.getUTCDate() - (n - 1) * 7);
    const sunday = new Date(thisMonday);
    sunday.setUTCDate(thisMonday.getUTCDate() + 6);
    return { weeksBack: n, monday, sunday };
  }

  function isoDate(d: Date): string {
    const y = d.getUTCFullYear();
    const m = String(d.getUTCMonth() + 1).padStart(2, '0');
    const day = String(d.getUTCDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  function isoWeekNumber(d: Date): number {
    const target = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));
    const dayNum = (target.getUTCDay() + 6) % 7;
    target.setUTCDate(target.getUTCDate() - dayNum + 3);
    const firstThursday = target.valueOf();
    target.setUTCMonth(0, 1);
    if (target.getUTCDay() !== 4) {
      target.setUTCMonth(0, 1 + ((4 - target.getUTCDay() + 7) % 7));
    }
    return 1 + Math.ceil((firstThursday - target.valueOf()) / (7 * 24 * 3600 * 1000));
  }

  function formatHm(sec: number): string {
    if (!sec) return '';
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    if (h === 0) return `${m}m`;
    if (m === 0) return `${h}h`;
    return `${h}h${String(m).padStart(2, '0')}`;
  }

  function sentenceCase(s: string): string {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function sourceLabel(a: Activity): string {
    if (a.externalSource === 'strava') return 'Strava';
    if (a.externalSource === 'garmin') return 'Garmin Connect';
    if (a.source === 'fit') return 'FIT upload';
    if (a.source === 'tcx') return 'TCX upload';
    if (a.source === 'gpx') return 'GPX upload';
    return 'Manual';
  }

  function sportGlyph(sport: string): string {
    const s = sport.toLowerCase();
    // 14×14 inline SVGs — currentColor flows from .cal-card-top.
    const path = ((): string => {
      if (s === 'cycling' || s === 'biking')
        return '<circle cx="5.5" cy="17.5" r="3.5"/><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/>';
      if (s === 'running')
        return '<path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.5.5 0 0 1-.96 0L10.29 3.18a.5.5 0 0 0-.96 0l-2.35 8.36A2 2 0 0 1 5.06 13H2"/>';
      if (s === 'swimming')
        return '<path d="M2 20a4 4 0 0 1 4-2 4 4 0 0 1 4 2 4 4 0 0 0 4 0 4 4 0 0 1 4-2 4 4 0 0 1 4 2"/><path d="M2 16a4 4 0 0 1 4-2 4 4 0 0 1 4 2 4 4 0 0 0 4 0 4 4 0 0 1 4-2 4 4 0 0 1 4 2"/><circle cx="17" cy="6" r="2"/>';
      return '<circle cx="12" cy="12" r="9"/>';
    })();
    return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${path}</svg>`;
  }

  function escape(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>
