---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Wordmark from '../components/Wordmark.astro';
---

<Base title="Create account">
  <div class="auth-shell">
    <div class="auth-card">
      <a href="/" aria-label="pacelore home">
        <Wordmark height={28} />
      </a>
      <div>
        <h2 class="h2" style="font-size: 22px;">Create your account</h2>
        <p class="muted body-sm" style="margin-top: 6px;">
          We use passkeys — no passwords. Your browser saves one to this device.
        </p>
      </div>

      <form id="register-form" class="stack" style="gap: 14px;">
        <div class="field">
          <label class="field-label" for="register-handle">Handle</label>
          <input
            id="register-handle"
            class="input"
            required
            name="handle"
            minlength="2"
            maxlength="32"
            pattern="[a-zA-Z0-9_-]+"
          />
          <span class="caption">Letters, numbers, underscore, dash.</span>
        </div>
        <div class="field">
          <label class="field-label" for="register-email">Email</label>
          <input
            id="register-email"
            class="input"
            required
            name="email"
            type="email"
            autocomplete="email"
          />
        </div>
        <button type="submit" class="btn btn-primary btn-lg">
          <Icon name="key" size={14} /> Create with passkey
        </button>
        <p id="register-status" class="caption" aria-live="polite"></p>
      </form>

      <p class="caption" style="text-align: center;">
        Already have an account?
        <a href="/login" style="color: var(--fg); text-decoration: underline;">Sign in</a>
      </p>
    </div>
  </div>
</Base>

<script>
  import { startRegistration } from '@simplewebauthn/browser';

  const form = document.getElementById('register-form') as HTMLFormElement;
  const status = document.getElementById('register-status')!;
  const submit = form.querySelector('button[type=submit]') as HTMLButtonElement;

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    status.textContent = '';
    submit.disabled = true;
    try {
      const data = new FormData(form);
      const handle = String(data.get('handle') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();

      const optionsRes = await fetch('/api/v1/auth/register/options', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ handle, email }),
      });
      if (!optionsRes.ok)
        throw new Error(
          (await optionsRes.json().catch(() => ({ error: optionsRes.statusText }))).error,
        );
      const { challengeId, userId, options } = await optionsRes.json();

      const attestation = await startRegistration({ optionsJSON: options });

      const verifyRes = await fetch('/api/v1/auth/register/verify', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          challengeId,
          userId,
          response: attestation,
          deviceName: navigator.userAgent.slice(0, 60),
        }),
      });
      if (!verifyRes.ok)
        throw new Error(
          (await verifyRes.json().catch(() => ({ error: verifyRes.statusText }))).error,
        );

      status.textContent = 'Account created — redirecting…';
      window.location.href = '/dashboard';
    } catch (err) {
      status.textContent = `Couldn't create account: ${(err as Error).message}`;
      submit.disabled = false;
    }
  });
</script>
