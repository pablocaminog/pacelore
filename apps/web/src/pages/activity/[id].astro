---
import Shell from '../../layouts/Shell.astro';
import Icon from '../../components/Icon.astro';
const { id } = Astro.params;
---

<Shell title="Activity" active="">
  <div class="stack" style="gap: 20px;">
    <a href="/feed" class="btn btn-ghost btn-sm" style="align-self: flex-start; padding: 6px 8px;">
      <Icon name="arrow-left" size={14} /> Back to feed
    </a>

    <header style="display: flex; align-items: flex-start; gap: 16px;">
      <div style="flex: 1;">
        <span class="metric-label">Activity</span>
        <h1 id="activity-title" class="h1" style="margin-top: 4px;">Loading…</h1>
        <p id="activity-subtitle" class="muted body-sm" style="margin-top: 4px;"></p>
      </div>
      <div style="display: flex; gap: 8px;">
        <a id="export-fit" class="btn btn-secondary btn-sm" href="#" hidden>
          <Icon name="download" size={14} /> Export FIT
        </a>
        <button class="btn btn-secondary btn-sm" type="button" id="share-btn">
          <Icon name="share-2" size={14} /> Share
        </button>
      </div>
    </header>

    <div id="activity-summary" class="grid-tiles grid-cols-6"></div>

    <div id="map-section" class="panel" hidden>
      <div class="panel-header">
        <h3 class="h3" style="font-size: 16px;">Route</h3>
      </div>
      <div id="route-map" style="height: 400px; width: 100%;"></div>
    </div>

    <div class="panel">
      <div class="panel-header">
        <h3 class="h3" style="font-size: 18px;">Time series</h3>
        <span class="row-end caption">power · heart rate · speed</span>
      </div>
      <div class="panel-body">
        <div id="time-chart" style="width: 100%;"></div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-header">
        <h3 class="h3" style="font-size: 16px;">Peak power curve</h3>
        <span class="row-end caption">log scale · 1s → 60m</span>
      </div>
      <div class="panel-body">
        <div id="peak-chart" style="width: 100%;"></div>
      </div>
    </div>

    <section id="comments" class="panel">
      <div class="panel-header">
        <h3 class="h3" style="font-size: 16px;">
          Kudos · <span id="kudos-count">0</span>
        </h3>
        <button id="kudos-btn" class="btn btn-secondary btn-sm row-end" type="button">
          <Icon name="zap" size={14} /> Give kudos
        </button>
      </div>
      <div class="panel-body stack" style="gap: 16px;">
        <ul id="comment-list" class="stack" style="list-style: none; padding: 0; margin: 0; gap: 14px;"></ul>
        <form id="comment-form" class="row" style="gap: 8px; padding-top: 8px; border-top: 1px solid var(--border);">
          <input
            id="comment-body"
            class="input"
            name="body"
            required
            maxlength="2000"
            placeholder="Reply…"
          />
          <button type="submit" class="btn btn-primary btn-sm">Send</button>
        </form>
      </div>
    </section>
  </div>
</Shell>

<script define:vars={{ activityId: id }}>
  window.__PACELORE_ACTIVITY_ID__ = activityId;
</script>

<script>
  import uPlot from 'uplot';
  import 'uplot/dist/uPlot.min.css';
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  type Sample = {
    t: number;
    hr?: number;
    power?: number;
    speed?: number;
    altitude?: number;
    lat?: number;
    lng?: number;
  };

  type ActivityRecord = {
    samples: Sample[];
    session: { sport: string; startedAt: string; totalSeconds: number };
  };

  type ActivityRow = {
    id: string;
    sport: string;
    name: string | null;
    startedAt: number;
    totalSeconds: number;
    distanceM: number | null;
    np: number | null;
    tss: number | null;
    powerAvg: number | null;
    hrAvg: number | null;
  };

  type Metric = { key: string; value: number };

  const id = (window as unknown as { __PACELORE_ACTIVITY_ID__: string }).__PACELORE_ACTIVITY_ID__;
  const title = document.getElementById('activity-title')!;
  const subtitle = document.getElementById('activity-subtitle')!;
  const summary = document.getElementById('activity-summary')!;

  init().catch((err) => {
    title.textContent = "Couldn't load activity";
    subtitle.textContent = (err as Error).message;
  });

  async function init() {
    const [meta, stream] = await Promise.all([
      fetch(`/api/v1/activities/${id}`, { credentials: 'include' }).then((r) => {
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        return r.json() as Promise<{ activity: ActivityRow; metrics: Metric[] }>;
      }),
      fetch(`/api/v1/activities/${id}/stream`, { credentials: 'include' }).then((r) => {
        if (!r.ok) throw new Error(`stream HTTP ${r.status}`);
        return r.json() as Promise<ActivityRecord>;
      }),
    ]);

    renderHeader(meta.activity);
    renderSummary(meta.activity, meta.metrics);
    renderRouteMap(stream.samples);
    renderTimeChart(stream.samples);
    renderPeakChart(meta.metrics);
    wireKudos(id);
    loadComments(id);
    wireCommentForm(id);
    wireExport(id);
  }

  function wireExport(activityId: string) {
    const a = document.getElementById('export-fit') as HTMLAnchorElement;
    a.href = `/api/v1/activities/${activityId}/raw`;
    a.hidden = false;
  }

  async function wireKudos(activityId: string) {
    const btn = document.getElementById('kudos-btn') as HTMLButtonElement;
    const countEl = document.getElementById('kudos-count')!;
    const refresh = async () => {
      const r = await fetch(`/api/v1/activities/${activityId}/kudos`, { credentials: 'include' });
      if (r.ok) {
        const body = (await r.json()) as { items: unknown[] };
        countEl.textContent = String(body.items.length);
      }
    };
    await refresh();
    btn.addEventListener('click', async () => {
      btn.disabled = true;
      try {
        await fetch(`/api/v1/activities/${activityId}/kudos`, {
          method: 'POST',
          credentials: 'include',
        });
        await refresh();
      } finally {
        btn.disabled = false;
      }
    });
  }

  async function loadComments(activityId: string) {
    const list = document.getElementById('comment-list')!;
    const r = await fetch(`/api/v1/activities/${activityId}/comments`, {
      credentials: 'include',
    });
    if (!r.ok) return;
    const body = (await r.json()) as {
      items: { id: string; handle: string; body: string; createdAt: number }[];
    };
    list.innerHTML = '';
    if (body.items.length === 0) {
      list.innerHTML = `<li class="caption">No comments yet.</li>`;
      return;
    }
    for (const c of body.items) {
      const li = document.createElement('li');
      const initials = (c.handle ?? '?')
        .split(/[\s_-]+/)
        .filter(Boolean)
        .slice(0, 2)
        .map((s) => s[0]?.toUpperCase() ?? '')
        .join('');
      const color = ((hash(c.handle) % 5) + 1) as 1 | 2 | 3 | 4 | 5;
      li.innerHTML = `
        <div style="display: flex; gap: 10px;">
          <span class="avatar sm" data-color="${color}"><span>${escape(initials || '?')}</span></span>
          <div style="flex: 1;">
            <div style="display: flex; gap: 8px; align-items: baseline;">
              <span style="font-size: 13px; font-weight: 600;">${escape(c.handle)}</span>
              <span class="metric-label" style="text-transform: none;">${escape(
                new Date(c.createdAt * 1000).toLocaleString(),
              )}</span>
            </div>
            <p class="body-sm" style="margin: 4px 0 0; white-space: pre-wrap;">${escape(c.body)}</p>
          </div>
        </div>
      `;
      list.appendChild(li);
    }
  }

  function wireCommentForm(activityId: string) {
    const form = document.getElementById('comment-form') as HTMLFormElement;
    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const fd = new FormData(form);
      const body = String(fd.get('body') ?? '').trim();
      if (!body) return;
      const r = await fetch(`/api/v1/activities/${activityId}/comments`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body }),
      });
      if (r.ok) {
        form.reset();
        await loadComments(activityId);
      }
    });
  }

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function hash(s: string): number {
    let h = 0;
    for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
    return Math.abs(h);
  }

  function renderHeader(a: ActivityRow) {
    title.textContent = a.name ?? `${sentenceCase(a.sport)} · ${formatDate(a.startedAt)}`;
    const dist = a.distanceM != null ? `${(a.distanceM / 1000).toFixed(1)} km` : '';
    subtitle.textContent = [
      sentenceCase(a.sport),
      formatDuration(a.totalSeconds),
      dist,
    ]
      .filter(Boolean)
      .join(' · ');
  }

  function renderSummary(a: ActivityRow, metrics: Metric[]) {
    const cells: { label: string; value: string; unit?: string }[] = [];
    if (a.distanceM != null)
      cells.push({ label: 'distance', value: (a.distanceM / 1000).toFixed(1), unit: ' km' });
    cells.push({ label: 'time', value: formatDuration(a.totalSeconds) });
    if (a.tss != null) cells.push({ label: 'tss', value: a.tss.toFixed(0) });
    if (a.np != null) cells.push({ label: 'np', value: String(Math.round(a.np)), unit: ' W' });
    if (a.powerAvg != null)
      cells.push({ label: 'avg power', value: String(Math.round(a.powerAvg)), unit: ' W' });
    if (a.hrAvg != null)
      cells.push({ label: 'avg hr', value: String(Math.round(a.hrAvg)), unit: ' bpm' });
    const trimp = metrics.find((m) => m.key === 'hr.trimp');
    if (trimp) cells.push({ label: 'trimp', value: trimp.value.toFixed(0) });
    const ifMetric = metrics.find((m) => m.key === 'power.if');
    if (ifMetric) cells.push({ label: 'if', value: ifMetric.value.toFixed(2) });
    summary.innerHTML = cells
      .slice(0, 6)
      .map((c) => {
        const key = labelToMetric(c.label);
        const labelAttr = key ? ` data-metric="${key}" tabindex="0"` : '';
        return `
          <div class="tile">
            <span class="label"${labelAttr}>${escape(c.label)}</span>
            <span class="v">${escape(c.value)}${c.unit ? `<span class="u">${escape(c.unit)}</span>` : ''}</span>
          </div>`;
      })
      .join('');
  }

  function labelToMetric(label: string): string | null {
    const m: Record<string, string> = {
      tss: 'tss',
      np: 'np',
      if: 'if',
      'avg power': 'np',
      'avg hr': 'rhr',
      trimp: 'trimp',
      elev: 'ascent',
      kj: 'kj',
    };
    return m[label.toLowerCase()] ?? null;
  }

  function renderRouteMap(samples: Sample[]) {
    const coords = samples
      .filter((s): s is Sample & { lat: number; lng: number } => s.lat != null && s.lng != null)
      .map((s) => [s.lng, s.lat] as [number, number]);
    if (coords.length < 2) return;

    const section = document.getElementById('map-section')!;
    section.hidden = false;

    let minLng = coords[0][0],
      maxLng = coords[0][0],
      minLat = coords[0][1],
      maxLat = coords[0][1];
    for (const [lng, lat] of coords) {
      if (lng < minLng) minLng = lng;
      if (lng > maxLng) maxLng = lng;
      if (lat < minLat) minLat = lat;
      if (lat > maxLat) maxLat = lat;
    }

    const map = new maplibregl.Map({
      container: 'route-map',
      style: 'https://tiles.openfreemap.org/styles/positron',
      bounds: [
        [minLng, minLat],
        [maxLng, maxLat],
      ],
      fitBoundsOptions: { padding: 32 },
    });

    map.on('load', () => {
      map.addSource('route', {
        type: 'geojson',
        data: {
          type: 'Feature',
          properties: {},
          geometry: { type: 'LineString', coordinates: coords },
        },
      });
      map.addLayer({
        id: 'route-line',
        type: 'line',
        source: 'route',
        paint: { 'line-color': '#C8FA1F', 'line-width': 3 },
      });
    });
  }

  function renderTimeChart(samples: Sample[]) {
    if (samples.length === 0) return;
    const t = samples.map((s) => s.t);
    const hr = samples.map((s) => s.hr ?? null);
    const power = samples.map((s) => s.power ?? null);
    const speed = samples.map((s) => (s.speed != null ? s.speed * 3.6 : null));
    const el = document.getElementById('time-chart')! as HTMLElement;

    const opts: uPlot.Options = {
      width: el.clientWidth || 900,
      height: 280,
      cursor: { drag: { x: true, y: false } },
      scales: { x: { time: false }, y: { auto: true } },
      series: [
        { label: 'sec' },
        { label: 'HR (bpm)', stroke: 'oklch(0.55 0.11 35)', width: 1.5 },
        { label: 'Power (W)', stroke: '#C8FA1F', width: 1.5 },
        { label: 'Speed (km/h)', stroke: 'oklch(0.58 0.08 220)', width: 1.5 },
      ],
    };
    new uPlot(opts, [t, hr, power, speed], el);
  }

  function renderPeakChart(metrics: Metric[]) {
    const peaks = metrics
      .filter((m) => m.key.startsWith('power.peak.'))
      .map((m) => ({ t: Number(m.key.split('.')[2]), v: m.value }))
      .sort((a, b) => a.t - b.t);
    if (peaks.length === 0) return;
    const el = document.getElementById('peak-chart')! as HTMLElement;

    const opts: uPlot.Options = {
      width: el.clientWidth || 900,
      height: 220,
      scales: { x: { time: false, distr: 3, log: 10 }, y: { auto: true } },
      axes: [{ label: 'duration (s)' }, { label: 'mean power (W)' }],
      series: [
        { label: 's' },
        { label: 'Peak (W)', stroke: '#C8FA1F', width: 2 },
      ],
    };
    new uPlot(opts, [peaks.map((p) => p.t), peaks.map((p) => p.v)], el);
  }

  function formatDuration(seconds: number) {
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = seconds % 60;
    if (h > 0) return `${h}h ${String(m).padStart(2, '0')}m`;
    return `${m}:${String(s).padStart(2, '0')}`;
  }

  function formatDate(epochSeconds: number) {
    return new Date(epochSeconds * 1000).toLocaleDateString(undefined, {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }

  function sentenceCase(s: string) {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  document.getElementById('share-btn')?.addEventListener('click', async () => {
    if (navigator.share) {
      try {
        await navigator.share({ url: location.href, title: document.title });
      } catch {}
    } else {
      await navigator.clipboard?.writeText(location.href);
    }
  });
</script>
