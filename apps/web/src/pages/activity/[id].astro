---
import Base from '../../layouts/Base.astro';
const { id } = Astro.params;
---

<Base title={`Activity · ${id}`}>
  <section class="space-y-6">
    <header>
      <p class="text-xs uppercase tracking-wider text-neutral-500">Activity</p>
      <h1 id="activity-title" class="text-2xl font-bold">Loading…</h1>
      <p id="activity-subtitle" class="text-sm text-neutral-600 dark:text-neutral-400"></p>
    </header>

    <dl id="activity-summary" class="grid grid-cols-2 gap-4 sm:grid-cols-4"></dl>

    <section id="map-section" class="hidden space-y-2">
      <h2 class="text-lg font-semibold">Route</h2>
      <div id="route-map" class="h-[400px] w-full rounded border border-neutral-200 dark:border-neutral-800"></div>
    </section>

    <section class="space-y-2">
      <h2 class="text-lg font-semibold">Time series</h2>
      <div id="time-chart" class="w-full"></div>
    </section>

    <section class="space-y-2">
      <h2 class="text-lg font-semibold">Peak power curve</h2>
      <div id="peak-chart" class="w-full"></div>
    </section>

    <section id="comments" class="space-y-3 pt-4">
      <div class="flex items-center gap-3">
        <button
          id="kudos-btn"
          class="rounded border border-neutral-300 px-3 py-1.5 text-sm hover:border-accent dark:border-neutral-700"
          >👍 Kudos · <span id="kudos-count">0</span></button
        >
      </div>
      <h2 class="text-lg font-semibold">Comments</h2>
      <ul id="comment-list" class="space-y-2 text-sm"></ul>
      <form id="comment-form" class="space-y-2">
        <textarea
          name="body"
          required
          maxlength="2000"
          rows="3"
          placeholder="Say something…"
          class="w-full rounded border border-neutral-300 px-3 py-2 text-sm dark:border-neutral-700 dark:bg-neutral-900"
        ></textarea>
        <button
          type="submit"
          class="rounded bg-accent px-3 py-1.5 text-sm font-medium text-white hover:opacity-90"
          >Post</button
        >
      </form>
    </section>
  </section>
</Base>

<script define:vars={{ activityId: id }}>
  // Pulled at runtime; the server only renders the shell.
  window.__OPEN_STRAVA_ACTIVITY__ = activityId;
</script>

<script>
  import uPlot from 'uplot';
  import 'uplot/dist/uPlot.min.css';
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  type Sample = {
    t: number;
    hr?: number;
    power?: number;
    speed?: number;
    altitude?: number;
    lat?: number;
    lng?: number;
  };

  type ActivityRecord = {
    samples: Sample[];
    session: { sport: string; startedAt: string; totalSeconds: number };
  };

  type ActivityRow = {
    id: string;
    sport: string;
    name: string | null;
    startedAt: number;
    totalSeconds: number;
    distanceM: number | null;
    np: number | null;
    tss: number | null;
    powerAvg: number | null;
    hrAvg: number | null;
  };

  type Metric = { key: string; value: number };

  const id = (window as unknown as { __OPEN_STRAVA_ACTIVITY__: string }).__OPEN_STRAVA_ACTIVITY__;
  const title = document.getElementById('activity-title')!;
  const subtitle = document.getElementById('activity-subtitle')!;
  const summary = document.getElementById('activity-summary')!;

  init().catch((err) => {
    title.textContent = 'Failed to load';
    subtitle.textContent = (err as Error).message;
  });

  async function init() {
    const [meta, stream] = await Promise.all([
      fetch(`/api/v1/activities/${id}`, { credentials: 'include' }).then((r) => {
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        return r.json() as Promise<{ activity: ActivityRow; metrics: Metric[] }>;
      }),
      fetch(`/api/v1/activities/${id}/stream`, { credentials: 'include' }).then((r) => {
        if (!r.ok) throw new Error(`stream HTTP ${r.status}`);
        return r.json() as Promise<ActivityRecord>;
      }),
    ]);

    renderHeader(meta.activity);
    renderSummary(meta.activity, meta.metrics);
    renderRouteMap(stream.samples);
    renderTimeChart(stream.samples);
    renderPeakChart(meta.metrics);
    wireKudos(id);
    loadComments(id);
    wireCommentForm(id);
  }

  async function wireKudos(activityId: string) {
    const btn = document.getElementById('kudos-btn') as HTMLButtonElement;
    const countEl = document.getElementById('kudos-count')!;
    const refresh = async () => {
      const r = await fetch(`/api/v1/activities/${activityId}/kudos`, { credentials: 'include' });
      if (r.ok) {
        const body = (await r.json()) as { items: unknown[] };
        countEl.textContent = String(body.items.length);
      }
    };
    await refresh();
    btn.addEventListener('click', async () => {
      btn.disabled = true;
      try {
        await fetch(`/api/v1/activities/${activityId}/kudos`, {
          method: 'POST',
          credentials: 'include',
        });
        await refresh();
      } finally {
        btn.disabled = false;
      }
    });
  }

  async function loadComments(activityId: string) {
    const list = document.getElementById('comment-list')!;
    const r = await fetch(`/api/v1/activities/${activityId}/comments`, { credentials: 'include' });
    if (!r.ok) return;
    const body = (await r.json()) as {
      items: { id: string; handle: string; body: string; createdAt: number }[];
    };
    list.innerHTML = '';
    for (const c of body.items) {
      const li = document.createElement('li');
      li.className = 'rounded border border-neutral-200 p-2 dark:border-neutral-800';
      li.innerHTML = `<strong>${escape(c.handle)}</strong> <span class="text-xs text-neutral-500">${escape(
        new Date(c.createdAt * 1000).toLocaleString(),
      )}</span><p class="mt-1 whitespace-pre-wrap">${escape(c.body)}</p>`;
      list.appendChild(li);
    }
  }

  function wireCommentForm(activityId: string) {
    const form = document.getElementById('comment-form') as HTMLFormElement;
    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const fd = new FormData(form);
      const body = String(fd.get('body') ?? '').trim();
      if (!body) return;
      const r = await fetch(`/api/v1/activities/${activityId}/comments`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body }),
      });
      if (r.ok) {
        form.reset();
        await loadComments(activityId);
      }
    });
  }

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderHeader(a: ActivityRow) {
    title.textContent = a.name ?? `${a.sport} · ${formatDate(a.startedAt)}`;
    subtitle.textContent = `${a.sport} · ${formatDuration(a.totalSeconds)}${
      a.distanceM ? ` · ${(a.distanceM / 1000).toFixed(2)} km` : ''
    }`;
  }

  function renderSummary(a: ActivityRow, metrics: Metric[]) {
    const cells: { label: string; value: string }[] = [];
    if (a.np != null) cells.push({ label: 'NP', value: `${Math.round(a.np)} W` });
    if (a.powerAvg != null) cells.push({ label: 'Avg power', value: `${Math.round(a.powerAvg)} W` });
    if (a.hrAvg != null) cells.push({ label: 'Avg HR', value: `${Math.round(a.hrAvg)} bpm` });
    if (a.tss != null) cells.push({ label: 'TSS', value: a.tss.toFixed(1) });
    const trimp = metrics.find((m) => m.key === 'hr.trimp');
    if (trimp) cells.push({ label: 'TRIMP', value: trimp.value.toFixed(1) });
    summary.innerHTML = cells
      .map(
        (c) =>
          `<div class="rounded border border-neutral-200 p-3 dark:border-neutral-800">
            <dt class="text-xs uppercase text-neutral-500">${c.label}</dt>
            <dd class="text-lg font-semibold">${c.value}</dd>
          </div>`,
      )
      .join('');
  }

  function renderRouteMap(samples: Sample[]) {
    const coords = samples
      .filter((s): s is Sample & { lat: number; lng: number } => s.lat != null && s.lng != null)
      .map((s) => [s.lng, s.lat] as [number, number]);
    if (coords.length < 2) return;

    const section = document.getElementById('map-section')!;
    section.classList.remove('hidden');

    let minLng = coords[0][0],
      maxLng = coords[0][0],
      minLat = coords[0][1],
      maxLat = coords[0][1];
    for (const [lng, lat] of coords) {
      if (lng < minLng) minLng = lng;
      if (lng > maxLng) maxLng = lng;
      if (lat < minLat) minLat = lat;
      if (lat > maxLat) maxLat = lat;
    }

    const map = new maplibregl.Map({
      container: 'route-map',
      style: 'https://tiles.openfreemap.org/styles/liberty',
      bounds: [
        [minLng, minLat],
        [maxLng, maxLat],
      ],
      fitBoundsOptions: { padding: 32 },
    });

    map.on('load', () => {
      map.addSource('route', {
        type: 'geojson',
        data: {
          type: 'Feature',
          properties: {},
          geometry: { type: 'LineString', coordinates: coords },
        },
      });
      map.addLayer({
        id: 'route-line',
        type: 'line',
        source: 'route',
        paint: { 'line-color': '#fc4c02', 'line-width': 3 },
      });
    });
  }

  function renderTimeChart(samples: Sample[]) {
    if (samples.length === 0) return;
    const t = samples.map((s) => s.t);
    const hr = samples.map((s) => s.hr ?? null);
    const power = samples.map((s) => s.power ?? null);
    const speed = samples.map((s) => (s.speed != null ? s.speed * 3.6 : null));

    const opts: uPlot.Options = {
      width: 900,
      height: 300,
      cursor: { drag: { x: true, y: false } },
      scales: { x: { time: false }, y: { auto: true } },
      series: [
        { label: 'sec' },
        { label: 'HR (bpm)', stroke: '#ef4444' },
        { label: 'Power (W)', stroke: '#fc4c02' },
        { label: 'Speed (km/h)', stroke: '#3b82f6' },
      ],
    };

    const el = document.getElementById('time-chart')!;
    new uPlot(opts, [t, hr, power, speed], el);
  }

  function renderPeakChart(metrics: Metric[]) {
    const peaks = metrics
      .filter((m) => m.key.startsWith('power.peak.'))
      .map((m) => ({ t: Number(m.key.split('.')[2]), v: m.value }))
      .sort((a, b) => a.t - b.t);
    if (peaks.length === 0) return;

    const opts: uPlot.Options = {
      width: 900,
      height: 250,
      scales: { x: { time: false, distr: 3, log: 10 }, y: { auto: true } },
      axes: [{ label: 'duration (s)' }, { label: 'mean power (W)' }],
      series: [
        { label: 's' },
        { label: 'Peak (W)', stroke: '#fc4c02' },
      ],
    };

    const el = document.getElementById('peak-chart')!;
    new uPlot(
      opts,
      [peaks.map((p) => p.t), peaks.map((p) => p.v)],
      el,
    );
  }

  function formatDuration(seconds: number) {
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = seconds % 60;
    return `${h}h ${String(m).padStart(2, '0')}m ${String(s).padStart(2, '0')}s`;
  }

  function formatDate(epochSeconds: number) {
    return new Date(epochSeconds * 1000).toLocaleString();
  }
</script>
