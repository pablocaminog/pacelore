---
import Shell from '../layouts/Shell.astro';
---

<Shell title="Feed" active="feed">
  <div style="display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 24px;">
    <section>
      <header class="row" style="margin-bottom: 16px;">
        <h1 class="h1" style="font-size: 28px;">Feed</h1>
        <div class="segmented row-end">
          <button class="on" type="button" data-feed-tab="following">Following</button>
          <button type="button" data-feed-tab="clubs">Clubs</button>
          <button type="button" data-feed-tab="discover">Discover</button>
        </div>
      </header>
      <p id="feed-subtitle" class="muted body-sm" style="margin-bottom: 16px;">Loading…</p>
      <ul id="feed-list" class="stack" style="list-style: none; padding: 0; margin: 0;"></ul>
      <div style="display: flex; justify-content: center; padding: 16px;">
        <button id="feed-more" class="btn btn-secondary btn-sm" hidden>Load more</button>
      </div>
    </section>

    <aside class="stack" style="gap: 16px;">
      <div class="panel">
        <div class="panel-header">
          <span class="metric-label">This week</span>
        </div>
        <div class="panel-body grid-tiles grid-cols-2">
          <div class="tile">
            <span class="label">distance</span>
            <span class="v">184.2<span class="u"> km</span></span>
          </div>
          <div class="tile">
            <span class="label">time</span>
            <span class="v">8:42<span class="u">:11</span></span>
          </div>
          <div class="tile">
            <span class="label" data-metric="tss" tabindex="0">tss</span>
            <span class="v">612</span>
            <span class="delta">+38 vs last</span>
          </div>
          <div class="tile">
            <span class="label" data-metric="ctl" tabindex="0">ctl</span>
            <span class="v">74.0</span>
            <span class="delta">+2.1</span>
          </div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-header">
          <span class="metric-label">Quick actions</span>
        </div>
        <div class="panel-body stack" style="gap: 10px;">
          <a class="btn btn-primary btn-sm" href="/upload">Import activities</a>
          <a class="btn btn-secondary btn-sm" href="/dashboard">Open PMC dashboard</a>
          <a class="btn btn-secondary btn-sm" href="/workouts">Workout library</a>
        </div>
      </div>
    </aside>
  </div>
</Shell>

<script>
  type Item = {
    id: string;
    athleteId: string;
    handle: string;
    displayName: string | null;
    sport: string;
    name: string | null;
    startedAt: number;
    totalSeconds: number;
    distanceM: number | null;
    np: number | null;
    tss: number | null;
  };

  const list = document.getElementById('feed-list')!;
  const subtitle = document.getElementById('feed-subtitle')!;
  const moreBtn = document.getElementById('feed-more') as HTMLButtonElement;
  let cursor: string | null = null;

  load().catch((err) => (subtitle.textContent = `Couldn't load feed: ${(err as Error).message}`));
  moreBtn.addEventListener('click', () =>
    load().catch((err) => (subtitle.textContent = `Couldn't load feed: ${err}`)),
  );

  async function load() {
    const url = cursor ? `/api/v1/feed?cursor=${cursor}` : '/api/v1/feed';
    const res = await fetch(url, { credentials: 'include' });
    if (!res.ok) {
      if (res.status === 401) {
        subtitle.innerHTML = `Sign in to see your feed — <a href="/login" style="color: var(--fg); text-decoration: underline;">go to sign in</a>.`;
        return;
      }
      throw new Error(`HTTP ${res.status}`);
    }
    const body = (await res.json()) as { items: Item[]; nextCursor: string | null };
    if (cursor === null) {
      subtitle.textContent =
        body.items.length === 0
          ? 'No activities yet. Upload one to get started.'
          : `${body.items.length} most recent`;
    }
    for (const it of body.items) list.appendChild(renderItem(it));
    cursor = body.nextCursor;
    moreBtn.hidden = !cursor;
  }

  function renderItem(it: Item): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'activity';

    const date = new Date(it.startedAt * 1000);
    const when = date.toLocaleString(undefined, {
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
    const dist = it.distanceM != null ? `${(it.distanceM / 1000).toFixed(1)} km` : '—';
    const dur = formatDuration(it.totalSeconds);
    const tss = it.tss != null ? it.tss.toFixed(0) : '—';
    const fourthLabel = it.np != null ? 'np' : 'pace';
    const fourth = it.np != null ? `${Math.round(it.np)} W` : '—';

    const display = it.displayName ?? it.handle;
    const initials = display
      .split(/[\s_-]+/)
      .filter(Boolean)
      .slice(0, 2)
      .map((s) => s[0]?.toUpperCase() ?? '')
      .join('') || display.slice(0, 2).toUpperCase();
    const color = ((hash(it.athleteId) % 5) + 1) as 1 | 2 | 3 | 4 | 5;

    li.innerHTML = `
      <a class="activity-top" href="/activity/${escape(it.id)}" style="text-decoration: none; color: inherit;">
        <span class="avatar" data-color="${color}"><span>${escape(initials)}</span></span>
        <span class="activity-who">
          <span class="n">${escape(display)}</span>
          <span class="m">${escape(when)}</span>
        </span>
        <span class="sport-tag">${escape(it.sport)}</span>
      </a>
      <div class="activity-body">
        <a href="/activity/${escape(it.id)}" style="text-decoration: none; color: inherit;">
          <h3 class="activity-title">${escape(it.name ?? sentenceCase(it.sport))}</h3>
        </a>
        <p class="activity-sub">${escape(dur)} · ${escape(dist)}${it.tss != null ? ` · TSS ${tss}` : ''}</p>
      </div>
      <div class="activity-stats">
        <div class="activity-stat"><span class="metric-label">distance</span><span class="v">${escape(dist)}</span></div>
        <div class="activity-stat"><span class="metric-label">time</span><span class="v">${escape(dur)}</span></div>
        <div class="activity-stat"><span class="metric-label">tss</span><span class="v">${escape(tss)}</span></div>
        <div class="activity-stat"><span class="metric-label">${fourthLabel}</span><span class="v">${escape(fourth)}</span></div>
      </div>
      <div class="activity-actions">
        <button type="button" class="activity-action kudos-btn" data-id="${escape(it.id)}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Kudos
        </button>
        <a class="activity-action" href="/activity/${escape(it.id)}#comments">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          Comment
        </a>
        <a class="activity-action" href="/activity/${escape(it.id)}" style="margin-left: auto;">Open
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    `;
    li.querySelector('.kudos-btn')!.addEventListener('click', async (ev) => {
      const btn = ev.currentTarget as HTMLButtonElement;
      const id = btn.dataset.id!;
      btn.disabled = true;
      try {
        const res = await fetch(`/api/v1/activities/${id}/kudos`, {
          method: 'POST',
          credentials: 'include',
        });
        if (res.ok) {
          btn.classList.add('kudoed');
          btn.lastChild!.textContent = ' Kudoed';
        }
      } finally {
        btn.disabled = false;
      }
    });
    return li;
  }

  function formatDuration(s: number) {
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    if (h === 0) return `${m}m`;
    return `${h}h ${String(m).padStart(2, '0')}m`;
  }

  function sentenceCase(s: string) {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function hash(s: string): number {
    let h = 0;
    for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
    return Math.abs(h);
  }

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>
