---
import Base from '../layouts/Base.astro';
---

<Base title="Logout · pacelore">
  <section class="mx-auto max-w-md space-y-4">
    <h1 class="text-2xl font-bold">Signing you out…</h1>
    <p id="logout-status" class="text-sm text-neutral-600 dark:text-neutral-400"></p>
  </section>
</Base>

<script>
  const status = document.getElementById('logout-status')!;
  fetch('/api/v1/auth/logout', { method: 'POST', credentials: 'include' })
    .then(() => {
      status.textContent = 'Signed out. Redirecting…';
      setTimeout(() => (window.location.href = '/'), 500);
    })
    .catch((err) => {
      status.textContent = `Error: ${err}`;
    });
</script>
