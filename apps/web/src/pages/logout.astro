---
import Base from '../layouts/Base.astro';
import Wordmark from '../components/Wordmark.astro';
---

<Base title="Sign out">
  <div class="auth-shell">
    <div class="auth-card" style="text-align: center;">
      <a href="/" aria-label="pacelore home" style="align-self: center;">
        <Wordmark height={26} />
      </a>
      <h2 class="h2" style="font-size: 22px;">Signing you out…</h2>
      <p id="logout-status" class="muted body-sm"></p>
    </div>
  </div>
</Base>

<script>
  const status = document.getElementById('logout-status')!;
  fetch('/api/v1/auth/logout', { method: 'POST', credentials: 'include' })
    .then(() => {
      status.textContent = 'Signed out. Redirecting…';
      setTimeout(() => (window.location.href = '/'), 500);
    })
    .catch((err) => {
      status.textContent = `Couldn't sign out: ${err}`;
    });
</script>
