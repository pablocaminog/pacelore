---
import Shell from '../layouts/Shell.astro';
import Icon from '../components/Icon.astro';
---

<Shell title="Settings" active="settings">
  <div class="stack" style="gap: 20px; max-width: 760px;">
    <header>
      <h1 class="h1" style="font-size: 28px;">Settings</h1>
      <p class="muted body-sm" style="margin-top: 4px;">
        Thresholds drive every load metric — set them honestly. Connections pull activities in;
        keys let third parties read on your behalf.
      </p>
    </header>

    <form id="settings-form" class="stack" style="gap: 16px;">
      <div class="panel">
        <div class="panel-header"><h3 class="h3" style="font-size: 16px;">Profile</h3></div>
        <div class="panel-body grid-tiles grid-cols-2" style="gap: 16px;">
          <div class="field">
            <label class="field-label">Display name</label>
            <input class="input" name="displayName" />
          </div>
          <div class="field">
            <label class="field-label">Location</label>
            <input class="input" name="location" placeholder="City" />
          </div>
          <div class="field" style="grid-column: span 2;">
            <label class="field-label">Bio</label>
            <textarea class="textarea" name="bio"></textarea>
          </div>
          <div class="field">
            <label class="field-label">Units</label>
            <select class="select" name="unitsPref">
              <option value="metric">Metric (km, kg)</option>
              <option value="imperial">Imperial (mi, lb)</option>
            </select>
          </div>
          <div class="field">
            <label class="field-label">Sex</label>
            <select class="select" name="sex">
              <option value="unspecified">Unspecified</option>
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-header">
          <h3 class="h3" style="font-size: 16px;">Thresholds</h3>
          <span class="row-end caption">Used to compute IF, TSS, TRIMP, and zones.</span>
        </div>
        <div class="panel-body grid-tiles grid-cols-2" style="gap: 16px;">
          <div class="field">
            <label class="field-label">FTP (W)</label>
            <input class="input mono" type="number" name="ftp" />
          </div>
          <div class="field">
            <label class="field-label">HRmax (bpm)</label>
            <input class="input mono" type="number" name="hrMax" />
          </div>
          <div class="field">
            <label class="field-label">HRrest (bpm)</label>
            <input class="input mono" type="number" name="hrRest" />
          </div>
          <div class="field">
            <label class="field-label">Threshold pace (m/s × 100)</label>
            <input class="input mono" type="number" name="thresholdPaceMsX100" />
          </div>
        </div>
      </div>

      <div class="row" style="gap: 12px;">
        <button class="btn btn-primary" type="submit">Save changes</button>
        <p id="save-status" class="caption" aria-live="polite"></p>
      </div>
    </form>

    <div class="panel">
      <div class="panel-header"><h3 class="h3" style="font-size: 16px;">Connected accounts</h3></div>
      <div class="panel-body stack" style="gap: 14px;">
        <div class="row" style="gap: 12px;">
          <div style="flex: 1;">
            <div style="font-size: 14px; font-weight: 600;">Strava</div>
            <p class="caption" style="margin: 2px 0 0;">
              Backfills the last 90 days. Also brings in Zwift rides synced to Strava.
            </p>
          </div>
          <a href="/api/v1/auth/strava/start" class="btn btn-primary btn-sm">Connect</a>
          <button id="strava-import" type="button" class="btn btn-secondary btn-sm">Import</button>
        </div>
        <div class="row" style="gap: 12px;">
          <div style="flex: 1;">
            <div style="font-size: 14px; font-weight: 600;">Garmin Connect</div>
            <p class="caption" style="margin: 2px 0 0;">
              Auto-ingest via push webhooks. Requires Garmin developer access.
            </p>
          </div>
          <a href="/api/v1/auth/garmin/start" class="btn btn-primary btn-sm">Connect</a>
        </div>
        <div class="row" style="gap: 12px;">
          <div style="flex: 1;">
            <div style="font-size: 14px; font-weight: 600;">Zwift</div>
            <p class="caption" style="margin: 2px 0 0;">
              No public API — connect Strava above (Zwift posts there), or upload the FIT file from
              <code>Documents/Zwift/Activities/</code> on the
              <a href="/upload" style="color: var(--fg); text-decoration: underline;">upload page</a>.
            </p>
          </div>
        </div>
        <div class="row" style="gap: 12px;">
          <div style="flex: 1;">
            <div style="font-size: 14px; font-weight: 600;">Apple Health</div>
            <p class="caption" style="margin: 2px 0 0;">Requires the native iOS app — TBD.</p>
          </div>
          <span class="chip chip-muted">Coming soon</span>
        </div>
      </div>
    </div>

    <div class="panel" style="border-color: var(--danger);">
      <div class="panel-header" style="border-color: var(--danger);">
        <h3 class="h3" style="font-size: 16px; color: var(--danger);">Delete account</h3>
      </div>
      <div class="panel-body stack" style="gap: 12px;">
        <p class="caption" style="margin: 0;">
          Closes your account and schedules all activity files, metrics, and feed history for
          purge from D1 + R2 within 30 days. Backups roll out within 90.
        </p>
        <p class="caption" style="margin: 0;">
          Type your handle to confirm. We'll email a confirmation to your address.
        </p>
        <form id="delete-form" class="row" style="gap: 8px;">
          <input
            id="delete-confirm"
            class="input mono"
            placeholder="Your handle"
            style="max-width: 240px;"
          />
          <button class="btn btn-danger" type="submit">Permanently delete</button>
          <span id="delete-status" class="caption" aria-live="polite"></span>
        </form>
      </div>
    </div>

    <div class="panel">
      <div class="panel-header"><h3 class="h3" style="font-size: 16px;">API keys</h3></div>
      <div class="panel-body stack" style="gap: 12px;">
        <p class="caption">
          For the public REST API and the MCP server. The secret is shown once at mint time.
        </p>
        <ul id="key-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 8px;"></ul>
        <details>
          <summary class="btn btn-secondary btn-sm" style="cursor: pointer;">
            <Icon name="plus" size={14} /> Mint a new key
          </summary>
          <form id="mint-form" class="stack" style="gap: 8px; margin-top: 12px;">
            <input class="input" name="name" placeholder="Key name" />
            <label class="row" style="gap: 8px; font-size: 13px;">
              <input type="checkbox" name="scope" value="read:activities" checked />
              read:activities
            </label>
            <label class="row" style="gap: 8px; font-size: 13px;">
              <input type="checkbox" name="scope" value="read:social" /> read:social
            </label>
            <label class="row" style="gap: 8px; font-size: 13px;">
              <input type="checkbox" name="scope" value="write:social" /> write:social
            </label>
            <button class="btn btn-primary btn-sm" type="submit">Mint</button>
            <pre
              id="minted"
              class="code"
              style="white-space: pre-wrap; padding: 12px; min-height: 24px;"></pre>
          </form>
        </details>
      </div>
    </div>
  </div>
</Shell>

<script>
  const form = document.getElementById('settings-form') as HTMLFormElement;
  const status = document.getElementById('save-status')!;
  const keyList = document.getElementById('key-list')!;
  const minted = document.getElementById('minted')!;
  const mintForm = document.getElementById('mint-form') as HTMLFormElement;

  init();

  async function init() {
    const r = await fetch('/api/v1/me/settings', { credentials: 'include' });
    if (!r.ok) {
      status.innerHTML = `Sign in to manage settings — <a href="/login" style="color: var(--fg); text-decoration: underline;">go to sign in</a>.`;
      return;
    }
    const { user } = (await r.json()) as { user: Record<string, unknown> };
    for (const [k, v] of Object.entries(user)) {
      const el = form.elements.namedItem(k) as
        | HTMLInputElement
        | HTMLTextAreaElement
        | HTMLSelectElement
        | null;
      if (el && v != null) el.value = String(v);
    }
    await loadKeys();
  }

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    status.textContent = '';
    const payload: Record<string, unknown> = {};
    new FormData(form).forEach((v, k) => {
      const sv = String(v);
      if (sv === '') return;
      if (['ftp', 'hrMax', 'hrRest', 'thresholdPaceMsX100'].includes(k)) {
        const n = Number(sv);
        if (Number.isFinite(n)) payload[k] = n;
      } else {
        payload[k] = sv;
      }
    });
    const r = await fetch('/api/v1/me/settings', {
      method: 'PATCH',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    status.textContent = r.ok ? 'Saved.' : `Couldn't save · HTTP ${r.status}`;
  });

  async function loadKeys() {
    const r = await fetch('/api/v1/me/api-keys', { credentials: 'include' });
    if (!r.ok) return;
    const body = (await r.json()) as {
      items: { id: string; name: string | null; scopes: string; revokedAt: number | null }[];
    };
    keyList.innerHTML = '';
    if (body.items.length === 0) {
      keyList.innerHTML = `<li class="caption">No keys yet.</li>`;
      return;
    }
    for (const k of body.items) {
      const li = document.createElement('li');
      li.className = 'panel';
      const status = k.revokedAt
        ? `<span class="chip chip-muted">revoked</span>`
        : `<span class="chip chip-success">active</span>`;
      li.innerHTML = `
        <div style="padding: 12px 16px; display: flex; align-items: center; gap: 12px;">
          <code style="flex: 1; font-size: 12px;">${escape(k.id)}</code>
          <span style="font-size: 13px;">${escape(k.name ?? '(unnamed)')}</span>
          <span class="caption">${escape(k.scopes)}</span>
          ${status}
        </div>
      `;
      if (!k.revokedAt) {
        const btn = document.createElement('button');
        btn.className = 'btn btn-ghost btn-sm';
        btn.style.color = 'var(--danger)';
        btn.textContent = 'Revoke';
        btn.addEventListener('click', async () => {
          const dr = await fetch(`/api/v1/me/api-keys/${k.id}`, {
            method: 'DELETE',
            credentials: 'include',
          });
          if (dr.ok) loadKeys();
        });
        li.querySelector('div')!.appendChild(btn);
      }
      keyList.appendChild(li);
    }
  }

  const stravaImportBtn = document.getElementById('strava-import') as HTMLButtonElement | null;
  if (stravaImportBtn) {
    stravaImportBtn.addEventListener('click', async () => {
      stravaImportBtn.disabled = true;
      stravaImportBtn.textContent = 'Importing…';
      try {
        const r = await fetch('/api/v1/me/import/strava', {
          method: 'POST',
          credentials: 'include',
        });
        if (r.ok) {
          const body = (await r.json()) as { queued: number };
          stravaImportBtn.textContent = `Queued ${body.queued}`;
        } else {
          stravaImportBtn.textContent = `Failed (${r.status})`;
        }
      } finally {
        setTimeout(() => {
          stravaImportBtn.disabled = false;
          stravaImportBtn.textContent = 'Import';
        }, 3000);
      }
    });
  }

  const deleteForm = document.getElementById('delete-form') as HTMLFormElement | null;
  deleteForm?.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const status = document.getElementById('delete-status')!;
    const input = document.getElementById('delete-confirm') as HTMLInputElement;
    const confirmHandle = input.value.trim();
    if (!confirmHandle) {
      status.textContent = 'Type your handle to confirm.';
      return;
    }
    if (
      !confirm(
        `This will permanently delete your account and schedule all data for purge. Type ${confirmHandle} only if you mean it.`,
      )
    )
      return;
    const r = await fetch('/api/v1/me', {
      method: 'DELETE',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ confirm: confirmHandle }),
    });
    if (r.ok) {
      status.textContent = 'Account deleted. Redirecting…';
      setTimeout(() => (window.location.href = '/'), 1500);
    } else {
      const detail = await r.json().catch(() => ({}));
      status.textContent =
        (detail as { error?: string }).error ?? `Couldn't delete · HTTP ${r.status}`;
    }
  });

  mintForm.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const fd = new FormData(mintForm);
    const scopes = fd.getAll('scope').map(String);
    const name = String(fd.get('name') ?? '');
    const r = await fetch('/api/v1/me/api-keys', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, scopes }),
    });
    if (r.ok) {
      const body = (await r.json()) as { key: string };
      minted.textContent = `Save this — shown only once:\n\n${body.key}`;
      await loadKeys();
    }
  });

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>
