---
import Marketing from '../layouts/Marketing.astro';

// If the visitor already has a valid session, jump straight to the feed.
const cookie = Astro.request.headers.get('cookie');
if (cookie) {
  try {
    const me = await fetch(new URL('/api/v1/auth/me', Astro.url), {
      headers: { cookie },
      redirect: 'manual',
    });
    if (me.ok) return Astro.redirect('/feed');
  } catch {
    // fall through to landing
  }
}

const faq = [
  {
    q: 'Is pacelore really free for athletes?',
    a: 'Yes. Every analytics feature on this page — TSS, NP, IF, peak power curves, GAP, decoupling, CTL/ATL/TSB, calendar, segments — is available on the free tier with no caps. No paywall on metrics, ever. Source-available under PolyForm Noncommercial 1.0.0.',
  },
  {
    q: 'How does this compare to Strava Premium?',
    a: 'Strava Premium charges roughly $80/year and still gates time-in-zone, segment effort history, and the matched runs comparison. pacelore gives you the same numbers — plus power-based TSS, NP, IF, peak power curves, and a real PMC dashboard — at zero cost.',
  },
  {
    q: 'How does this compare to TrainingPeaks Premium?',
    a: 'TrainingPeaks Premium is $240/year and is the canonical home of the PMC chart. pacelore implements the same Banister CTL/ATL/TSB model with daily TSS rollup, plus zone analysis and peak power curves. The model is the same; the price is not.',
  },
  {
    q: 'Can I import my whole Strava history?',
    a: 'Yes. Connect Strava in /upload and click "Backfill all". pacelore walks the Strava activity list back to your account creation, respects the 100 req / 15 min and 1000 / day limits, and dedups against itself so you can re-run it safely. Long histories continue overnight via cron.',
  },
  {
    q: 'What about Garmin?',
    a: 'OAuth1.0a connect + push webhooks for activities, plus daily summaries, sleep, body composition, and user metrics (VO2max, RHR, HRV) — wired and waiting on Garmin Health/Activity API partner approval, which is a per-company application.',
  },
  {
    q: 'Is my data really portable?',
    a: 'Yes. Every activity is stored as the original FIT/TCX/GPX in R2 and re-exportable from the dashboard. Optional Arweave permanence backup. Optional ATProto export to your own PDS. No lock-in.',
  },
  {
    q: 'What happens if you stop maintaining pacelore?',
    a: 'The full source is on GitHub under PolyForm Noncommercial 1.0.0. The whole stack runs on Cloudflare. Anyone can fork the repo, deploy to their own Cloudflare account in under ten minutes, and keep their data flowing. The license blocks commercial reuse but explicitly permits self-hosting.',
  },
  {
    q: 'Where\'s the mobile app?',
    a: 'Web is the primary surface today and works on phones. Native iOS app with HealthKit integration is on the roadmap; Garmin Connect / Strava push webhooks already cover most of what a "record an activity" app would do. Calendar + dashboard are read-only on mobile.',
  },
  {
    q: 'Why "noncommercial"?',
    a: 'PolyForm Noncommercial 1.0.0 keeps the source readable, runnable, and self-hostable by anyone — but blocks resale and commercial wrappers. The point is to keep pacelore from being acquired and turned into the next thing it\'s replacing. Personal, hobby, research, and nonprofit use are explicitly allowed.',
  },
  {
    q: 'How is this so cheap to run?',
    a: 'The whole stack — Workers, D1, R2, KV, Queues, Email — sits on Cloudflare\'s edge. Autoscales to zero. Per-athlete infra cost is around $0.012/month at 10k active users. Detailed cost breakdown lives in ARCHITECTURE.md.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'pacelore',
    description:
      'Source-available training platform. TSS, NP, IF, peak power curves, GAP, decoupling, CTL/ATL/TSB. Free Strava + TrainingPeaks alternative.',
    applicationCategory: 'HealthApplication',
    operatingSystem: 'Web',
    url: 'https://pacelore.com',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    license: 'https://polyformproject.org/licenses/noncommercial/1.0.0/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Marketing
  title="pacelore"
  description="Source-available training platform. TSS, NP, IF, peak power curves, GAP, decoupling, CTL/ATL/TSB. Connect Garmin or Strava, import your full history, own your data. Free for athletes, forever."
  jsonLd={jsonLd}
>
  <div class="marketing-content">

    <!-- ============== HERO ============== -->
    <section class="marketing-hero">
      <span class="metric-label">Source-available · free for athletes · runs on Cloudflare</span>
      <h1>Strava analytics. TrainingPeaks PMC. Free.</h1>
      <p>
        Connect <strong>Garmin</strong> or <strong>Strava</strong>, import your whole history, and pacelore
        computes the metrics that matter: <span data-metric="tss" tabindex="0">TSS</span>,
        <span data-metric="np" tabindex="0">NP</span>,
        <span data-metric="if" tabindex="0">IF</span>, peak power curves,
        <span data-metric="gap" tabindex="0">GAP</span>,
        <span data-metric="decoupling" tabindex="0">decoupling</span>, and
        <span data-metric="ctl" tabindex="0">CTL</span>/<span data-metric="atl" tabindex="0">ATL</span>/<span
          data-metric="tsb"
          tabindex="0">TSB</span
        >. Your data, your archive. Free forever — no caps, no paywall, no upsell.
      </p>
      <div class="marketing-actions">
        <a class="btn btn-primary btn-lg" href="/register">Create account — free, forever</a>
        <a class="btn btn-secondary btn-lg" href="/demo">Try the demo →</a>
        <a class="btn btn-ghost btn-lg" href="https://github.com/pablocaminog/pacelore">Source on GitHub</a>
      </div>
      <p class="caption" style="margin: 0;">
        Connect Strava in under a minute · No credit card · Self-host on Cloudflare in under 10 minutes
      </p>
    </section>

    <!-- ============== HERO MOCK ============== -->
    <section
      class="panel"
      aria-label="Sample dashboard"
      style="overflow: hidden;"
    >
      <div class="panel-header">
        <span class="metric-label">Performance management — last 90 days</span>
        <span class="row-end caption" style="font-family: var(--font-mono);">
          <span class="pulse-dot" style="display: inline-block; vertical-align: middle; margin-right: 8px;"></span>
          live edge data
        </span>
      </div>
      <div class="panel-body" style="padding: 0;">
        <svg
          viewBox="0 0 1080 460"
          width="100%"
          height="auto"
          style="display: block;"
          aria-hidden="true"
        >
          <!-- chart frame -->
          <rect width="1080" height="460" fill="var(--surface)" />

          <!-- four metric tiles -->
          <g font-family='"Geist Mono", ui-monospace, Menlo, monospace'>
            <g transform="translate(20, 20)">
              <rect width="248" height="78" rx="8" fill="var(--surface-2)" stroke="var(--border)" />
              <text x="14" y="22" font-size="11" fill="var(--fg-muted)" letter-spacing="1.5">CTL · FITNESS</text>
              <text x="14" y="55" font-size="30" font-weight="600" fill="var(--fg)" letter-spacing="-1">76.2</text>
              <text x="14" y="71" font-size="11" fill="oklch(0.58 0.11 150)">+2.1 in 7d</text>
            </g>
            <g transform="translate(280, 20)">
              <rect width="248" height="78" rx="8" fill="var(--surface-2)" stroke="var(--border)" />
              <text x="14" y="22" font-size="11" fill="var(--fg-muted)" letter-spacing="1.5">ATL · FATIGUE</text>
              <text x="14" y="55" font-size="30" font-weight="600" fill="var(--fg)" letter-spacing="-1">84.1</text>
              <text x="14" y="71" font-size="11" fill="oklch(0.55 0.17 30)">+8.3 in 7d</text>
            </g>
            <g transform="translate(540, 20)">
              <rect width="248" height="78" rx="8" fill="var(--surface-2)" stroke="var(--border)" />
              <text x="14" y="22" font-size="11" fill="var(--fg-muted)" letter-spacing="1.5">TSB · FORM</text>
              <text x="14" y="55" font-size="30" font-weight="600" fill="var(--fg)" letter-spacing="-1">−7.9</text>
              <text x="14" y="71" font-size="11" fill="oklch(0.55 0.17 30)">loaded</text>
            </g>
            <g transform="translate(800, 20)">
              <rect width="260" height="78" rx="8" fill="var(--surface-2)" stroke="var(--border)" />
              <text x="14" y="22" font-size="11" fill="var(--fg-muted)" letter-spacing="1.5">7-DAY TSS</text>
              <text x="14" y="55" font-size="30" font-weight="600" fill="var(--fg)" letter-spacing="-1">612</text>
              <text x="14" y="71" font-size="11" fill="oklch(0.58 0.11 150)">+38 vs avg</text>
            </g>
          </g>

          <!-- chart area -->
          <g transform="translate(20, 130)">
            <rect width="1040" height="280" fill="var(--surface)" stroke="var(--border)" rx="8" />
            <!-- gridlines -->
            <g stroke="var(--border)" stroke-width="1">
              <line x1="40" x2="1020" y1="40" y2="40" stroke-dasharray="2 4" />
              <line x1="40" x2="1020" y1="100" y2="100" stroke-dasharray="2 4" />
              <line x1="40" x2="1020" y1="160" y2="160" stroke-dasharray="2 4" />
              <line x1="40" x2="1020" y1="220" y2="220" stroke-dasharray="2 4" />
            </g>
            <!-- TSB shaded area (volt-soft) -->
            <path
              d="M40 220 L120 215 L200 200 L280 195 L360 205 L440 215 L520 195 L600 175 L680 165 L760 175 L840 160 L920 150 L1000 145 L1020 145 L1020 220 Z"
              fill="oklch(0.66 0.11 150 / 0.18)"
            />
            <!-- ATL dashed -->
            <path
              d="M40 175 L120 160 L200 145 L280 130 L360 145 L440 160 L520 130 L600 100 L680 85 L760 100 L840 75 L920 60 L1000 55"
              stroke="var(--ink-700)"
              stroke-width="1.5"
              stroke-dasharray="6 4"
              fill="none"
            />
            <!-- CTL solid -->
            <path
              d="M40 195 L120 180 L200 165 L280 150 L360 155 L440 145 L520 130 L600 115 L680 100 L760 95 L840 85 L920 80 L1000 75"
              stroke="#C8FA1F"
              stroke-width="2.5"
              fill="none"
            />
            <!-- markers on CTL line -->
            <g fill="#C8FA1F">
              <circle cx="40" cy="195" r="3" />
              <circle cx="280" cy="150" r="3" />
              <circle cx="600" cy="115" r="3" />
              <circle cx="1000" cy="75" r="3" />
            </g>

            <!-- annotations -->
            <g font-family='"Geist Mono", ui-monospace, Menlo, monospace' font-size="11">
              <line x1="1010" y1="75" x2="1024" y2="62" stroke="var(--fg-muted)" stroke-width="1" />
              <text x="1024" y="58" fill="var(--fg)" font-weight="600">CTL 76</text>
              <line x1="1010" y1="55" x2="1024" y2="42" stroke="var(--fg-muted)" stroke-width="1" />
              <text x="1024" y="38" fill="var(--ink-700)">ATL 84</text>
              <text x="60" y="232" fill="var(--fg-muted)">3/7</text>
              <text x="290" y="232" fill="var(--fg-muted)">3/28</text>
              <text x="610" y="232" fill="var(--fg-muted)">4/18</text>
              <text x="900" y="232" fill="var(--fg-muted)">5/6</text>
            </g>
          </g>

          <!-- legend / heatmap strip -->
          <g transform="translate(20, 425)" font-family='"Geist Mono", ui-monospace' font-size="11">
            <text x="0" y="10" fill="var(--fg-muted)" letter-spacing="1.5">DAILY TSS</text>
            <g transform="translate(110, 0)">
              <rect width="14" height="14" rx="3" fill="var(--zone-0)" stroke="var(--border)" />
              <rect x="20" width="14" height="14" rx="3" fill="var(--zone-1)" />
              <rect x="40" width="14" height="14" rx="3" fill="var(--zone-2)" />
              <rect x="60" width="14" height="14" rx="3" fill="var(--zone-3)" />
              <rect x="80" width="14" height="14" rx="3" fill="var(--zone-4)" />
              <rect x="100" width="14" height="14" rx="3" fill="var(--zone-5)" />
              <text x="130" y="11" fill="var(--fg-muted)">rest → peak</text>
            </g>
            <g transform="translate(900, 0)" fill="var(--fg-muted)">
              <text>peak day 142 TSS</text>
            </g>
          </g>
        </svg>
      </div>
    </section>

    <!-- ============== COMPARISON ============== -->
    <section id="compare" class="stack" style="gap: 16px;">
      <div>
        <h2 class="h2">Side by side</h2>
        <p class="muted body-sm" style="margin-top: 4px;">
          Premium tiers compared as of May 2026. Pricing taken from each platform's public site.
        </p>
      </div>
      <div class="panel" style="overflow-x: auto;">
        <table class="lb" style="min-width: 720px;">
          <thead>
            <tr>
              <th>Feature</th>
              <th>Strava Premium</th>
              <th>TrainingPeaks Premium</th>
              <th style="background: var(--accent-soft); color: var(--pace-700);">pacelore</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Annual price</td>
              <td class="num">~$80 / yr</td>
              <td class="num">$240 / yr</td>
              <td class="num" style="background: var(--accent-soft);"><strong>$0</strong></td>
            </tr>
            <tr>
              <td><span data-metric="tss" tabindex="0">TSS</span> · <span data-metric="np" tabindex="0">NP</span> · <span data-metric="if" tabindex="0">IF</span></td>
              <td>partial</td>
              <td>yes</td>
              <td style="background: var(--accent-soft);">yes</td>
            </tr>
            <tr>
              <td>Peak power curve (mean-max)</td>
              <td>premium-gated</td>
              <td>yes</td>
              <td style="background: var(--accent-soft);">yes</td>
            </tr>
            <tr>
              <td><span data-metric="pmc" tabindex="0">PMC</span> · CTL / ATL / TSB</td>
              <td>—</td>
              <td>yes (Banister model)</td>
              <td style="background: var(--accent-soft);">yes (Banister model)</td>
            </tr>
            <tr>
              <td>Time in zone</td>
              <td>premium-gated</td>
              <td>yes</td>
              <td style="background: var(--accent-soft);">yes</td>
            </tr>
            <tr>
              <td><span data-metric="gap" tabindex="0">GAP</span> · grade-adjusted pace</td>
              <td>premium-gated</td>
              <td>yes</td>
              <td style="background: var(--accent-soft);">yes (Minetti model)</td>
            </tr>
            <tr>
              <td>Segments + leaderboards</td>
              <td>yes</td>
              <td>—</td>
              <td style="background: var(--accent-soft);">yes</td>
            </tr>
            <tr>
              <td>Social feed · kudos · comments</td>
              <td>yes</td>
              <td>—</td>
              <td style="background: var(--accent-soft);">yes</td>
            </tr>
            <tr>
              <td>Free FIT / TCX / GPX export</td>
              <td>per-activity only</td>
              <td>yes</td>
              <td style="background: var(--accent-soft);">yes (raw + parsed)</td>
            </tr>
            <tr>
              <td>Open public API</td>
              <td>throttled, app-keyed</td>
              <td>partial</td>
              <td style="background: var(--accent-soft);">REST + MCP, free</td>
            </tr>
            <tr>
              <td>Source available</td>
              <td>—</td>
              <td>—</td>
              <td style="background: var(--accent-soft);"><strong>yes</strong></td>
            </tr>
            <tr>
              <td>Self-hosting</td>
              <td>—</td>
              <td>—</td>
              <td style="background: var(--accent-soft);">10-minute Cloudflare deploy</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="caption">
        "Strava", "TrainingPeaks", "Garmin Connect" are trademarks of their respective owners. pacelore
        is not affiliated with any of them.
      </p>
    </section>

    <!-- ============== MIGRATE FROM STRAVA ============== -->
    <section
      class="panel"
      style="background: linear-gradient(180deg, var(--accent-soft), var(--surface)); border-color: var(--pace-300);"
    >
      <div class="panel-body grid-tiles" style="grid-template-columns: 1.1fr 1fr; gap: 32px; padding: 32px;">
        <div class="stack" style="gap: 16px;">
          <span class="metric-label" style="color: var(--pace-700);">Migration</span>
          <h2 class="h2" style="margin: 0;">Bring your whole Strava history in 90 seconds</h2>
          <p class="body" style="margin: 0;">
            Click <strong>Connect Strava</strong>, authorize, hit <strong>Backfill all</strong>. pacelore
            walks the whole archive back to your account creation, throttled inside Strava's rate
            limits, deduped against itself. Long histories continue overnight via cron — no tab to
            keep open.
          </p>
          <ul class="stack" style="gap: 8px; padding: 0; list-style: none; font-size: 14px;">
            <li>✓ TCX synthesized from <code>/activities</code> + <code>/streams</code> — full HR / power / pace / cadence</li>
            <li>✓ Re-import safe — <code>(strava, activity_id)</code> dedup</li>
            <li>✓ Pulls Zwift rides synced to Strava automatically</li>
            <li>✓ Activities populate PMC + zone analysis as they land</li>
          </ul>
          <div class="row" style="gap: 12px; margin-top: 4px;">
            <a class="btn btn-primary" href="/register">Start free</a>
            <a class="btn btn-ghost" href="/login">Sign in</a>
          </div>
        </div>
        <div
          aria-hidden="true"
          style="background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 20px; font-family: var(--font-mono); font-size: 13px;"
        >
          <div class="row" style="gap: 8px; margin-bottom: 14px;">
            <span class="chip chip-success">running</span>
            <span class="metric-label" style="margin-left: auto;">strava backfill</span>
          </div>
          <div class="stack" style="gap: 6px;">
            <div class="row"><span class="muted">cursor at</span><span class="row-end">2018-04-12</span></div>
            <div class="row"><span class="muted">imported</span><span class="row-end">1,284</span></div>
            <div class="row"><span class="muted">duplicates</span><span class="row-end">0</span></div>
            <div class="row"><span class="muted">failed</span><span class="row-end">0</span></div>
          </div>
          <div style="height: 6px; background: var(--ink-100); border-radius: 9999px; margin-top: 18px; overflow: hidden;">
            <div style="height: 100%; width: 64%; background: var(--pace-500);"></div>
          </div>
          <p class="caption" style="margin-top: 8px;">cron drains 4 jobs/min · ETA 18 min</p>
        </div>
      </div>
    </section>

    <!-- ============== FEATURES ============== -->
    <section id="features" class="stack" style="gap: 16px;">
      <h2 class="h2">What you get</h2>
      <div class="marketing-features">
        <article class="marketing-feature">
          <h3>Unpaywalled analytics</h3>
          <p>
            <span data-metric="tss" tabindex="0">TSS</span> · <span data-metric="np" tabindex="0">NP</span>
            · <span data-metric="if" tabindex="0">IF</span> · <span data-metric="vi" tabindex="0">VI</span>
            · kJ · peak power curves · HR zones · <span data-metric="gap" tabindex="0">GAP</span> ·
            <span data-metric="decoupling" tabindex="0">decoupling</span> ·
            <span data-metric="trimp" tabindex="0">TRIMP</span> · rTSS. Coggan and Banister models,
            implemented honestly.
          </p>
        </article>
        <article class="marketing-feature">
          <h3>PMC dashboard</h3>
          <p>
            42-day <span data-metric="ctl" tabindex="0">CTL</span> · 7-day
            <span data-metric="atl" tabindex="0">ATL</span> · daily
            <span data-metric="tsb" tabindex="0">TSB</span>. The same model TrainingPeaks invented,
            with a calendar heatmap and zone ramp legend.
          </p>
        </article>
        <article class="marketing-feature">
          <h3>Data sovereignty</h3>
          <p>
            Free FIT / TCX / GPX export. Optional Arweave permanence backup. Optional ATProto export
            to your own PDS. Your activities, your archive, no lock-in.
          </p>
        </article>
        <article class="marketing-feature">
          <h3>Workout library</h3>
          <p>
            60 calibrated sessions across cycling, running, swimming. Filter by sport, duration, and
            intensity zone. Export to FIT for Garmin or .zwo for Zwift.
          </p>
        </article>
        <article class="marketing-feature">
          <h3>Social, but quiet</h3>
          <p>
            Follow graph, kudos, threaded comments, segments with leaderboards, clubs, events. Public
            / followers / private — your call, per activity.
          </p>
        </article>
        <article class="marketing-feature">
          <h3>Source-available</h3>
          <p>
            <a
              href="https://github.com/pablocaminog/pacelore"
              style="color: var(--fg); text-decoration: underline;">PolyForm Noncommercial 1.0.0</a
            >. Self-host on your own Cloudflare account in under 10 minutes. Nothing important behind
            a paywall.
          </p>
        </article>
      </div>
    </section>

    <!-- ============== SAMPLE NUMBERS ============== -->
    <section class="marketing-numbers">
      <div class="tile">
        <span class="label">free tier</span>
        <span class="v">$0</span>
        <span class="delta flat">all core analytics, forever</span>
      </div>
      <div class="tile">
        <span class="label">export</span>
        <span class="v">FIT · TCX · GPX</span>
        <span class="delta flat">your data, anytime</span>
      </div>
      <div class="tile">
        <span class="label">infra</span>
        <span class="v">edge<span class="u"> · cloudflare</span></span>
        <span class="delta flat">global, autoscaling</span>
      </div>
      <div class="tile">
        <span class="label">license</span>
        <span class="v">PolyForm</span>
        <span class="delta flat">noncommercial 1.0.0</span>
      </div>
    </section>

    <!-- ============== FAQ ============== -->
    <section id="faq" class="stack" style="gap: 16px;">
      <h2 class="h2">Questions</h2>
      <div class="stack" style="gap: 8px;">
        {
          faq.map((f) => (
            <details class="panel">
              <summary
                style="cursor: pointer; padding: 14px 20px; font-weight: 600; font-size: 15px; list-style: none;"
              >
                {f.q}
              </summary>
              <div
                class="panel-body"
                style="padding-top: 0; border-top: 1px solid var(--border); color: var(--fg);"
              >
                {f.a}
              </div>
            </details>
          ))
        }
      </div>
    </section>

    <!-- ============== FINAL CTA ============== -->
    <section
      class="panel"
      style="background: var(--ink-900); color: var(--ink-0); border-color: var(--ink-800); text-align: center;"
    >
      <div class="panel-body stack" style="gap: 16px; padding: 48px 24px;">
        <h2 class="h2" style="color: var(--ink-0);">Stop renting your training data.</h2>
        <p class="body" style="color: var(--ink-200); max-width: 56ch; margin: 0 auto;">
          One account. Free forever. Connect Garmin or Strava and get every metric on this page in
          the next two minutes.
        </p>
        <div class="row" style="gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a class="btn btn-primary btn-lg" href="/register">Create account</a>
          <a
