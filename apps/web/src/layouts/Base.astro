---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'pacelore', description = 'open-source training platform' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="border-b border-neutral-200 dark:border-neutral-800">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <a href="/" class="font-semibold tracking-tight">pacelore</a>
        <nav class="flex gap-4 text-sm text-neutral-600 dark:text-neutral-400">
          <a href="/feed" class="hover:text-accent">Feed</a>
          <a href="/upload" class="hover:text-accent">Upload</a>
          <a href="/dashboard" class="hover:text-accent">Dashboard</a>
          <a href="/calendar" class="hover:text-accent">Calendar</a>
          <a href="/login" class="hover:text-accent">Login</a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>
    <footer class="mt-16 border-t border-neutral-200 px-4 py-6 text-center text-xs text-neutral-500 dark:border-neutral-800">
      AGPL-3.0 ·
      <a href="https://github.com/pablocaminog/pacelore" class="hover:text-accent">source</a>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
