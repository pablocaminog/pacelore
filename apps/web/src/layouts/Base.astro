---
import Glossary from '../components/Glossary.astro';

interface Props {
  title?: string;
  description?: string;
  /** When set, used verbatim as <title>. Otherwise we suffix with `· pacelore`. */
  titleOverride?: string;
  ogImage?: string;
  /** Optional <link rel="canonical"> override. Defaults to current URL. */
  canonical?: string;
  /** JSON-LD structured data block. Pages can pass FAQ / SoftwareApplication etc. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const {
  title = 'pacelore',
  description = 'Source-available training platform with TSS, IF, NP, peak power curves, GAP, decoupling, and CTL/ATL/TSB. The Strava + TrainingPeaks alternative that\'s free for athletes, forever.',
  titleOverride,
  ogImage = '/og.svg',
  canonical,
  jsonLd,
} = Astro.props;

const fullTitle =
  titleOverride ??
  (title === 'pacelore'
    ? 'pacelore — free Strava + TrainingPeaks alternative · TSS, NP, IF, PMC'
    : `${title} · pacelore`);

// Canonical: strip protocol-or-not weirdness so apex/www collapse.
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, 'https://pacelore.com').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0E1012" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="pacelore" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, 'https://pacelore.com').toString()} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, 'https://pacelore.com').toString()} />

    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500;600&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&display=swap"
    />
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
          is:inline
        />
      )
    }
    <title>{fullTitle}</title>
  </head>
  <body>
    <slot />
    <Glossary />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
