---
import Base from './Base.astro';
import Icon from '../components/Icon.astro';
import Wordmark from '../components/Wordmark.astro';

interface Props {
  title?: string;
  description?: string;
  active?:
    | 'feed'
    | 'activities'
    | 'calendar'
    | 'pmc'
    | 'segments'
    | 'clubs'
    | 'events'
    | 'workouts'
    | 'challenges'
    | 'settings'
    | 'upload'
    | '';
}
const { title, description, active = '' } = Astro.props;

const navTraining: { id: string; label: string; href: string; icon: string }[] = [
  { id: 'feed', label: 'Feed', href: '/feed', icon: 'rss' },
  { id: 'activities', label: 'Activities', href: '/upload', icon: 'activity' },
  { id: 'calendar', label: 'Calendar', href: '/calendar', icon: 'calendar' },
  { id: 'pmc', label: 'PMC', href: '/dashboard', icon: 'trending-up' },
  { id: 'workouts', label: 'Workouts', href: '/workouts', icon: 'flag' },
];
const navCommunity: { id: string; label: string; href: string; icon: string }[] = [
  { id: 'segments', label: 'Segments', href: '/segments', icon: 'map' },
  { id: 'clubs', label: 'Clubs', href: '/clubs', icon: 'users' },
  { id: 'events', label: 'Events', href: '/events', icon: 'calendar-days' },
  { id: 'challenges', label: 'Challenges', href: '/challenges', icon: 'trophy' },
];
---

<Base title={title} description={description}>
  <div class="app">
    <aside class="rail">
      <a href="/" class="brand" aria-label="pacelore home">
        <Wordmark height={26} />
      </a>
      <span class="nav-section">Training</span>
      {
        navTraining.map((n) => (
          <a href={n.href} class={active === n.id ? 'active' : ''}>
            <Icon name={n.icon} size={18} />
            {n.label}
          </a>
        ))
      }
      <span class="nav-section">Community</span>
      {
        navCommunity.map((n) => (
          <a href={n.href} class={active === n.id ? 'active' : ''}>
            <Icon name={n.icon} size={18} />
            {n.label}
          </a>
        ))
      }
      <span class="nav-section">You</span>
      <a href="/settings" class={active === 'settings' ? 'active' : ''}>
        <Icon name="settings" size={18} /> Settings
      </a>
      <a href="/logout">
        <Icon name="log-out" size={18} /> Sign out
      </a>
    </aside>

    <header class="topbar">
      <div class="search">
        <span class="search-icon"><Icon name="search" size={16} /></span>
        <input
          id="topbar-search"
          type="search"
          placeholder="Search activities, athletes, segments…"
          autocomplete="off"
        />
      </div>
      <button class="iconbtn" type="button" title="Notifications" aria-label="Notifications">
        <Icon name="bell" size={18} />
      </button>
      <a class="upload-btn" href="/upload">
        <Icon name="upload" size={14} /> Upload
      </a>
      <a id="topbar-avatar" class="avatar" data-color="5" href="/settings" title="Profile">
        <span>—</span>
      </a>
    </header>

    <main class="content">
      <slot />
    </main>
  </div>
</Base>

<script>
  // Populate avatar initials from /api/v1/auth/me. Silent on 401.
  const av = document.getElementById('topbar-avatar');
  if (av) {
    fetch('/api/v1/auth/me', { credentials: 'include' })
      .then((r) => (r.ok ? r.json() : null))
      .then((body) => {
        if (!body) return;
        const u = (body as { user: { handle: string; displayName?: string | null } }).user;
        const name = u.displayName ?? u.handle ?? '';
        const initials = name
          .split(/[\s_-]+/)
          .filter(Boolean)
          .slice(0, 2)
          .map((s) => s[0]?.toUpperCase() ?? '')
          .join('');
        av.querySelector('span')!.textContent = initials || name.slice(0, 2).toUpperCase();
      })
      .catch(() => {});
  }
</script>
