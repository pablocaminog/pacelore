---
interface Props {
  height?: number;
  class?: string;
}
const { height = 26, class: cls = '' } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 320 64"
  fill="none"
  aria-label="pacelore"
  height={height}
  class={cls}
  style={`color: var(--fg); height: ${height}px; width: auto;`}
>
  <g stroke="currentColor" stroke-linecap="round" opacity="0.45">
    <line x1="32" y1="3" x2="32" y2="7" stroke-width="1.5"></line>
    <line x1="32" y1="57" x2="32" y2="61" stroke-width="1.5"></line>
    <line x1="3" y1="32" x2="7" y2="32" stroke-width="1.5"></line>
    <line x1="57" y1="32" x2="61" y2="32" stroke-width="1.5"></line>
    <line x1="13.5" y1="13.5" x2="16.3" y2="16.3" stroke-width="1"></line>
    <line x1="47.7" y1="47.7" x2="50.5" y2="50.5" stroke-width="1"></line>
    <line x1="13.5" y1="50.5" x2="16.3" y2="47.7" stroke-width="1"></line>
    <line x1="47.7" y1="16.3" x2="50.5" y2="13.5" stroke-width="1"></line>
