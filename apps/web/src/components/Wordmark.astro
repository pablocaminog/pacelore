  <path
    d="M 14 50 Q 14 18 38 18 Q 52 18 52 30 Q 52 40 40 40 L 26 40"
    stroke="currentColor"
    stroke-width="6"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"
  ></path>
  <path d="M 26 40 L 44 52" stroke="#C8FA1F" stroke-width="6" stroke-linecap="round"></path>
  <circle cx="44" cy="52" r="3.5" fill="#C8FA1F"></circle>
  <circle cx="14" cy="50" r="3" fill="currentColor"></circle>
  <text
    x="80"
    y="42"
    font-family="Geist, Inter, system-ui, sans-serif"
    font-size="30"
    font-weight="600"
    letter-spacing="-0.02em"
    fill="currentColor">pacelore</text
  >
</svg>
