{
  "name": "pacelore",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source training platform — Strava + TrainingPeaks alternative on Cloudflare.",
  "license": "AGPL-3.0-only",
  "author": "Pablo Caminog <pcaminog@gmail.com>",
  "homepage": "https://github.com/pablocaminog/pacelore",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablocaminog/pacelore.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:web": "pnpm --filter @pacelore/web dev",
    "dev:api": "pnpm --filter @pacelore/api dev"
  },
  "devDependencies": {
    "@eslint/js": "9.15.0",
    "eslint": "9.15.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.4.1",
    "typescript": "5.6.3",
    "typescript-eslint": "8.16.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "workerd"
    ]
  }
}
