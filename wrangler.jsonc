{
  // Root wrangler config so the Cloudflare "Clone a repository" /
  // "Deploy to Cloudflare" flow can auto-detect the API worker.
  // Paths are relative to this file.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pacelore-api",
  "account_id": "72b9ea77edd80936fb97de334621368b",
  "main": "apps/api/src/index.ts",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "build": {
    "command": "pnpm install --frozen-lockfile=false && pnpm --filter @pacelore/api typecheck",
  },
  "vars": {
    "ENV": "production",
    "APP_ORIGIN": "https://pacelore.pages.dev",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pacelore",
      "database_id": "2070e24f-b8dd-4d71-b1b9-6a824ac883f5",
      "migrations_dir": "infra/wrangler/migrations",
    },
  ],
  "r2_buckets": [
    { "binding": "RAW_BUCKET", "bucket_name": "pacelore-raw" },
    { "binding": "PARSED_BUCKET", "bucket_name": "pacelore-parsed" },
    { "binding": "EXPORTS_BUCKET", "bucket_name": "pacelore-exports" },
  ],
  "kv_namespaces": [
    { "binding": "KV_SESSIONS", "id": "bec561a091284c2893c74433bc5aea81" },
    { "binding": "KV_LEADERBOARDS", "id": "77f5cb560b6f4f6abcdbd18f0769964b" },
    { "binding": "KV_FEED", "id": "867c1cdbbb7c4b2faea48caf690c3558" },
  ],
  "queues": {
    "producers": [{ "queue": "activity-ingest", "binding": "INGEST_QUEUE" }],
    "consumers": [
      {
        "queue": "activity-ingest",
        "max_batch_size": 5,
        "max_batch_timeout": 5,
        "max_retries": 3,
        "dead_letter_queue": "activity-ingest-dlq",
      },
    ],
  },
  "observability": {
    "logs": { "enabled": true },
  },
  "triggers": {
    "crons": ["0 5 * * *"],
  },
}
